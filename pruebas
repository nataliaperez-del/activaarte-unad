<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#003B71">
  <meta name="description" content="ACTiva Arte — Bienestar emocional ACT · UNAD">
  <title>ACTiva Arte — UNAD</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,900;1,400&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
    rel="stylesheet">
  <style>
    /* ═══════════════════════════════════════════
   RESET & TOKENS
═══════════════════════════════════════════ */
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box
    }

    html {
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%
    }

    :root {
      /* Identidad UNAD */
      --azul: #003B71;
      --azul-m: #005DA4;
      --azul-c: #0077C8;
      --verde: #5B9E3A;
      --amarillo: #F2A900;
      --gris: #58595B;
      /* Sistema */
      --salvia: #8DAA91;
      --terra: #C9825A;
      --crema: #F5F0E8;
      --lavanda: #B4A7C5;
      --aurora: #E8C4A0;
      --txt: #1A1A2E;
      --txt2: #4A5568;
      --fondo: #F4F6F9;
      --blanco: #FFFFFF;
      --borde: #E2E8F0;
      --sombra: 0 2px 12px rgba(0, 59, 113, .08);
      --sombra-lg: 0 8px 32px rgba(0, 59, 113, .14);
      --r: 14px;
      --rs: 8px;
      --rp: 999px;
    }

    body {
      font-family: 'Nunito', sans-serif;
      background: var(--fondo);
      color: var(--txt);
      line-height: 1.6;
      min-height: 100vh;
    }

    h1,
    h2,
    h3,
    h4 {
      font-family: 'Lora', serif;
      line-height: 1.25;
      font-weight: 600
    }

    img {
      max-width: 100%;
      display: block
    }

    button,
    input,
    textarea,
    select {
      font-family: inherit
    }

    a {
      text-decoration: none;
      color: inherit
    }

    /* ═══════════════════════════════════════════
   CONNECTIVITY BAR
═══════════════════════════════════════════ */
    #conn-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 9999;
      padding: 9px 20px;
      font-size: 13px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transform: translateY(-100%);
      transition: transform .3s cubic-bezier(.34, 1.56, .64, 1);
      pointer-events: none;
    }

    #conn-bar.show {
      transform: translateY(0);
      pointer-events: auto
    }

    #conn-bar.offline {
      background: #C0392B;
      color: #fff
    }

    #conn-bar.online {
      background: #1e8449;
      color: #fff
    }

    #conn-bar.syncing {
      background: var(--azul);
      color: #fff
    }

    .conn-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: currentColor;
      display: inline-block;
      flex-shrink: 0
    }

    .conn-btn {
      background: rgba(255, 255, 255, .22);
      border: 1px solid rgba(255, 255, 255, .35);
      color: #fff;
      border-radius: var(--rp);
      padding: 3px 12px;
      font-size: 11px;
      cursor: pointer;
      font-weight: 800
    }

    /* ═══════════════════════════════════════════
   STUDENT LAYOUT
═══════════════════════════════════════════ */
    #student-mode {
      display: none
    }

    /* HEADER */
    .stu-header {
      background: var(--azul);
      color: #fff;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 12px rgba(0, 0, 0, .18);
    }

    .stu-header-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
      display: flex;
      align-items: center;
      gap: 12px;
      height: 60px;
    }

    .stu-logo {
      display: flex;
      align-items: center;
      gap: 10px
    }

    .stu-logo-badge {
      background: var(--amarillo);
      color: var(--azul);
      font-weight: 900;
      font-size: 13px;
      border-radius: 6px;
      padding: 3px 8px;
      letter-spacing: .3px;
    }

    .stu-logo-name {
      font-family: 'Lora', serif;
      font-size: 16px;
      font-weight: 600;
      letter-spacing: .2px
    }

    .stu-header-actions {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 8px
    }

    .stu-pts {
      background: var(--amarillo);
      color: var(--azul);
      font-weight: 900;
      font-size: 12px;
      border-radius: var(--rp);
      padding: 4px 12px;
      position: relative;
    }

    #pending-badge {
      position: absolute;
      top: -6px;
      right: -6px;
      background: #e53e3e;
      color: #fff;
      border-radius: 50%;
      width: 16px;
      height: 16px;
      font-size: 9px;
      font-weight: 900;
      display: none;
      align-items: center;
      justify-content: center;
    }

    #pending-badge.show {
      display: flex
    }

    .stu-role-btn {
      background: rgba(255, 255, 255, .12);
      border: 1px solid rgba(255, 255, 255, .25);
      color: #fff;
      border-radius: var(--rp);
      padding: 6px 14px;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: background .2s;
    }

    .stu-role-btn:hover {
      background: rgba(255, 255, 255, .22)
    }

    /* APP CONTAINER */
    .stu-app {
      max-width: 680px;
      margin: 0 auto;
      padding: 24px 16px 100px
    }

    /* SCREENS */
    .screen {
      display: none;
      animation: fadeUp .3s ease forwards
    }

    .screen.active {
      display: block
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(14px)
      }

      to {
        opacity: 1;
        transform: translateY(0)
      }
    }

    /* ═══════════════════════════════════════════
   CARDS
═══════════════════════════════════════════ */
    .card {
      background: var(--blanco);
      border-radius: var(--r);
      box-shadow: var(--sombra);
      padding: 20px;
      margin-bottom: 16px;
      transition: box-shadow .2s;
      border: 1px solid var(--borde);
    }

    .card:hover {
      box-shadow: var(--sombra-lg)
    }

    /* BANNER */
    .banner {
      border-radius: var(--r) var(--r) 0 0;
      height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .banner::before {
      content: '';
      position: absolute;
      inset: 0
    }

    .banner-content {
      position: relative;
      z-index: 1;
      text-align: center;
      color: #fff;
      padding: 0 20px
    }

    .banner-emoji {
      font-size: 2.8rem;
      display: block;
      margin-bottom: 8px
    }

    .banner-title {
      font-family: 'Lora', serif;
      font-size: 1.55rem;
      font-weight: 600
    }

    .banner-sub {
      font-size: 13px;
      opacity: .85;
      margin-top: 3px
    }

    .banner-home::before {
      background: linear-gradient(135deg, var(--azul) 0%, var(--azul-c) 60%, var(--salvia) 100%)
    }

    .banner-checkin::before {
      background: linear-gradient(135deg, #1a1a3e, var(--azul) 55%, var(--lavanda))
    }

    .banner-module::before {
      background: linear-gradient(135deg, var(--verde), var(--salvia) 60%, var(--crema))
    }

    .banner-progress::before {
      background: linear-gradient(135deg, var(--terra), var(--amarillo) 60%, var(--aurora))
    }

    .banner-teacher::before {
      background: linear-gradient(135deg, #1a1a3e, #003B71 60%, #005DA4)
    }

    .banner::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 20% 60%, rgba(242, 169, 0, .18) 0%, transparent 55%), radial-gradient(circle at 80% 20%, rgba(91, 158, 58, .2) 0%, transparent 45%)
    }

    /* FORM CARD */
    .form-card {
      background: var(--blanco);
      border-radius: 0 0 var(--r) var(--r);
      padding: 24px;
      margin-bottom: 16px;
      box-shadow: var(--sombra);
      border: 1px solid var(--borde);
      border-top: none;
    }

    .form-card-header {
      background: var(--azul);
      border-top: 8px solid var(--amarillo);
      border-radius: var(--r) var(--r) 0 0;
      padding: 22px 24px 18px;
      color: #fff;
    }

    .form-card-header h2 {
      font-size: 1.3rem;
      color: #fff
    }

    .form-card-header p {
      font-size: 13px;
      opacity: .8;
      margin-top: 4px
    }

    /* ═══════════════════════════════════════════
   BUTTONS
═══════════════════════════════════════════ */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      border: none;
      border-radius: var(--rp);
      font-size: 15px;
      font-weight: 700;
      min-height: 48px;
      padding: 10px 24px;
      cursor: pointer;
      width: 100%;
      transition: transform .12s, box-shadow .2s, filter .15s;
    }

    .btn:active {
      transform: scale(.97)
    }

    .btn:focus-visible {
      outline: 3px solid var(--amarillo);
      outline-offset: 2px
    }

    .btn-primary {
      background: var(--azul-c);
      color: #fff
    }

    .btn-primary:hover {
      filter: brightness(1.1)
    }

    .btn-success {
      background: var(--verde);
      color: #fff
    }

    .btn-success:hover {
      filter: brightness(1.1)
    }

    .btn-gold {
      background: var(--amarillo);
      color: var(--azul)
    }

    .btn-ghost {
      background: transparent;
      color: var(--txt2);
      border: 1.5px solid var(--borde)
    }

    .btn-ghost:hover {
      border-color: var(--azul-c);
      color: var(--azul-c)
    }

    .btn-danger {
      background: #E53E3E;
      color: #fff
    }

    .btn-sm {
      min-height: 38px;
      font-size: 13px;
      padding: 7px 18px
    }

    .btn-pair {
      display: flex;
      gap: 10px
    }

    .btn-pair .btn {
      flex: 1
    }

    /* ═══════════════════════════════════════════
   FORMS
═══════════════════════════════════════════ */
    .form-group {
      margin-bottom: 20px
    }

    .form-label {
      display: block;
      font-weight: 700;
      font-size: 14px;
      margin-bottom: 8px;
      color: var(--azul)
    }

    .form-label .req {
      color: #E53E3E;
      margin-left: 3px
    }

    .form-label .opt {
      font-size: 12px;
      color: var(--txt2);
      font-weight: 400
    }

    .form-input {
      width: 100%;
      padding: 12px 14px;
      border: 1.5px solid var(--borde);
      border-radius: var(--rs);
      font-size: 15px;
      background: var(--blanco);
      transition: border-color .2s, box-shadow .2s;
      color: var(--txt);
    }

    .form-input:focus {
      outline: none;
      border-color: var(--azul-c);
      box-shadow: 0 0 0 3px rgba(0, 119, 200, .12)
    }

    textarea.form-input {
      resize: vertical
    }

    textarea.short {
      min-height: 70px
    }

    textarea.long {
      min-height: 130px
    }

    textarea.xl {
      min-height: 190px
    }

    .char-counter {
      text-align: right;
      font-size: 11px;
      color: var(--txt2);
      margin-top: 4px
    }

    .char-counter.warn {
      color: var(--terra)
    }

    .char-counter.ok {
      color: var(--verde)
    }

    .form-hint {
      font-size: 12px;
      color: var(--txt2);
      margin-top: 5px;
      font-style: italic
    }

    .range-wrap {
      display: flex;
      align-items: center;
      gap: 12px
    }

    input[type=range] {
      flex: 1;
      accent-color: var(--azul-c)
    }

    .range-val {
      min-width: 36px;
      text-align: center;
      font-weight: 700;
      background: var(--azul-c);
      color: #fff;
      border-radius: 6px;
      padding: 3px 8px;
      font-size: 14px
    }

    /* ═══════════════════════════════════════════
   ROLE SELECTION
═══════════════════════════════════════════ */
    .role-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 12px;
      margin: 16px 0;
    }

    .role-card {
      border: 2px solid var(--borde);
      border-radius: var(--r);
      padding: 20px 14px;
      text-align: center;
      cursor: pointer;
      background: var(--blanco);
      transition: transform .2s, border-color .2s, box-shadow .2s, background .2s;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      min-height: 140px;
      pointer-events: auto;
    }

    .role-card:hover {
      border-color: var(--azul-c);
      transform: translateY(-2px);
      box-shadow: var(--sombra-lg)
    }

    .role-card.selected {
      border-color: var(--azul);
      background: var(--azul);
      color: #fff
    }

    .role-card .r-icon {
      font-size: 2.4rem
    }

    .role-card .r-name {
      font-weight: 800;
      font-size: 1rem
    }

    .role-card .r-desc {
      font-size: 12px;
      opacity: .7
    }

    /* ═══════════════════════════════════════════
   EMOTIONS — CHECK-IN INMERSIVO
═══════════════════════════════════════════ */
    .checkin-intro {
      text-align: center;
      padding: 8px 0 16px
    }

    .checkin-intro .hora {
      font-size: 11px;
      color: var(--txt2);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 700;
      margin-bottom: 4px
    }

    .checkin-intro h3 {
      font-family: 'Lora', serif;
      font-size: 1.1rem;
      color: var(--azul);
      margin-bottom: 3px
    }

    .checkin-intro p {
      font-size: 13px;
      color: var(--txt2)
    }

    .em-select-hint {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--txt2);
      margin-bottom: 14px;
      flex-wrap: wrap
    }

    .em-select-hint strong {
      color: var(--azul)
    }

    .emotion-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin: 4px 0 6px
    }

    @media(max-width:400px) {
      .emotion-grid {
        grid-template-columns: 1fr 1fr
      }
    }

    .emotion-pill {
      border: 2.5px solid var(--borde);
      border-radius: 16px;
      padding: 18px 8px 14px;
      background: var(--blanco);
      cursor: pointer;
      text-align: center;
      position: relative;
      overflow: hidden;
      transition: transform .2s cubic-bezier(.34, 1.56, .64, 1), border-color .18s, box-shadow .18s, background .18s;
    }

    .emotion-pill::before {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity .2s;
      background: radial-gradient(circle at 50% 110%, rgba(0, 93, 164, .1) 0%, transparent 65%)
    }

    .emotion-pill:hover {
      border-color: var(--azul-c);
      transform: translateY(-3px);
      box-shadow: 0 6px 20px rgba(0, 59, 113, .13)
    }

    .emotion-pill:hover::before {
      opacity: 1
    }

    .emotion-pill:active {
      transform: scale(.96)
    }

    .emotion-pill.selected {
      transform: scale(1.07) translateY(-3px);
      box-shadow: 0 10px 28px rgba(0, 59, 113, .3);
      border-width: 2.5px;
    }

    .emotion-pill.selected.pos {
      background: linear-gradient(145deg, #1a6b2a, var(--verde));
      border-color: var(--verde);
      color: #fff;
      box-shadow: 0 10px 28px rgba(91, 158, 58, .38)
    }

    .emotion-pill.selected.neu {
      background: linear-gradient(145deg, #a07800, var(--amarillo));
      border-color: var(--amarillo);
      color: var(--azul);
      box-shadow: 0 10px 28px rgba(242, 169, 0, .38)
    }

    .emotion-pill.selected.neg {
      background: linear-gradient(145deg, var(--azul), var(--azul-m));
      border-color: var(--azul-c);
      color: #fff;
      box-shadow: 0 10px 28px rgba(0, 93, 164, .38)
    }

    .emotion-pill::after {
      content: '';
      position: absolute;
      top: 6px;
      right: 8px;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      border: 2px solid var(--borde);
      background: var(--blanco);
      transition: all .18s
    }

    .emotion-pill.selected::after {
      content: '✓';
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      font-weight: 900;
      border: none;
      background: rgba(255, 255, 255, .3);
      color: #fff;
    }

    .emotion-pill.selected.neu::after {
      color: var(--azul);
      background: rgba(0, 59, 113, .15)
    }

    .emotion-pill .em-icon {
      font-size: 2.1rem;
      display: block;
      margin-bottom: 6px;
      transition: transform .2s;
      line-height: 1
    }

    .emotion-pill:hover .em-icon {
      transform: scale(1.18)
    }

    .emotion-pill.selected .em-icon {
      transform: scale(1.22)
    }

    .emotion-pill .em-label {
      font-size: 12px;
      font-weight: 800;
      color: var(--txt2);
      display: block;
      letter-spacing: .2px
    }

    .emotion-pill.selected .em-label {
      color: #fff
    }

    .emotion-pill.selected.neu .em-label {
      color: var(--azul)
    }

    .emotion-pill .em-valencia {
      display: none
    }

    .emotion-pill.selected .em-valencia {
      display: none
    }

    .emotion-pill.selected.neu .em-valencia {
      display: none
    }

    .emotion-pill .em-count {
      font-size: 9px;
      color: var(--txt2);
      margin-top: 5px;
      background: var(--fondo);
      border-radius: var(--rp);
      padding: 1px 7px;
      display: inline-block
    }

    .emotion-pill.selected .em-count {
      background: rgba(255, 255, 255, .22);
      color: rgba(255, 255, 255, .8)
    }

    .emotion-pill.selected.neu .em-count {
      background: rgba(0, 59, 113, .12);
      color: var(--azul)
    }

    /* Panel feedback inteligente */
    .emotion-feedback {
      border-radius: var(--r);
      padding: 18px 20px;
      margin: 12px 0 4px;
      animation: fadeUp .3s ease;
    }

    .emotion-feedback.neg {
      background: linear-gradient(135deg, #0a2a4a, var(--azul));
      border-left: 4px solid var(--amarillo)
    }

    .emotion-feedback.pos {
      background: linear-gradient(135deg, #0f3d1c, #1a6b2a);
      border-left: 4px solid #7ed94a
    }

    .emotion-feedback.neu {
      background: linear-gradient(135deg, #3d2f00, #7a5f00);
      border-left: 4px solid var(--amarillo)
    }

    .emotion-feedback.mix {
      background: linear-gradient(135deg, var(--azul), var(--azul-m));
      border-left: 4px solid var(--salvia)
    }

    .ef-label {
      font-size: 10px;
      color: rgba(255, 255, 255, .6);
      text-transform: uppercase;
      letter-spacing: 1.2px;
      margin-bottom: 8px;
      font-weight: 700
    }

    .ef-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 10px
    }

    .ef-tag {
      border-radius: var(--rp);
      padding: 3px 11px;
      font-size: 12px;
      font-weight: 800;
      background: rgba(255, 255, 255, .18);
      color: #fff
    }

    .ef-tag.pos {
      background: rgba(126, 217, 74, .3)
    }

    .ef-tag.neu {
      background: rgba(242, 169, 0, .35);
      color: var(--azul)
    }

    .ef-tag.neg {
      background: rgba(0, 119, 200, .35)
    }

    .ef-score-bar {
      height: 4px;
      background: rgba(255, 255, 255, .15);
      border-radius: var(--rp);
      margin-bottom: 10px;
      overflow: hidden
    }

    .ef-score-fill {
      height: 100%;
      border-radius: var(--rp);
      background: var(--amarillo);
      transition: width .8s cubic-bezier(.34, 1.56, .64, 1)
    }

    .ef-mensaje {
      font-size: 14px;
      color: #fff;
      font-weight: 700;
      line-height: 1.55;
      margin-bottom: 4px
    }

    .ef-sub {
      font-size: 12px;
      color: rgba(255, 255, 255, .65);
      font-style: italic;
      line-height: 1.5
    }

    .ef-pill-rec {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255, 255, 255, .15);
      border-radius: var(--rp);
      padding: 5px 12px;
      font-size: 12px;
      color: #fff;
      font-weight: 700;
      margin-top: 10px;
      cursor: pointer;
      border: 1px solid rgba(255, 255, 255, .2);
      transition: background .2s;
    }

    .ef-pill-rec:hover {
      background: rgba(255, 255, 255, .25)
    }

    /* ═══════════════════════════════════════════
   DASHBOARD
═══════════════════════════════════════════ */
    .streak-bar {
      background: linear-gradient(135deg, var(--azul), var(--azul-m));
      color: #fff;
      border-radius: var(--r);
      padding: 20px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 4px 16px rgba(0, 59, 113, .25);
    }

    .streak-label {
      font-size: 11px;
      opacity: .7;
      text-transform: uppercase;
      letter-spacing: 1px
    }

    .streak-num {
      font-size: 2.2rem;
      font-weight: 900;
      color: var(--amarillo);
      line-height: 1
    }

    .progress-track {
      height: 6px;
      background: rgba(255, 255, 255, .18);
      border-radius: var(--rp);
      margin-top: 10px;
      width: 140px;
      overflow: hidden
    }

    .progress-fill {
      height: 100%;
      background: var(--amarillo);
      border-radius: var(--rp);
      transition: width .5s ease
    }

    .ex-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px
    }

    @media(max-width:420px) {
      .ex-grid {
        grid-template-columns: 1fr
      }
    }

    .card-ex {
      cursor: pointer;
      border: 2px solid var(--borde);
      border-radius: var(--r);
      padding: 16px;
      background: var(--blanco);
      transition: all .2s;
      display: flex;
      flex-direction: column;
      gap: 6px;
      box-shadow: var(--sombra);
    }

    .card-ex:hover {
      border-color: var(--azul-c);
      box-shadow: var(--sombra-lg);
      transform: translateY(-1px)
    }

    .card-ex.done {
      border-color: var(--verde)
    }

    .card-ex:active {
      transform: scale(.98)
    }

    .ex-icon {
      font-size: 1.8rem
    }

    .ex-title {
      font-family: 'Lora', serif;
      font-size: .95rem;
      font-weight: 600
    }

    .ex-sub {
      font-size: 11px;
      color: var(--txt2)
    }

    .ex-badge {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: var(--rp);
      font-weight: 700;
      display: inline-block;
      width: fit-content
    }

    .badge-done {
      background: rgba(91, 158, 58, .12);
      color: var(--verde);
      border: 1px solid rgba(91, 158, 58, .3)
    }

    .badge-pend {
      background: var(--fondo);
      color: var(--gris)
    }

    .card-ex {
      opacity: 0;
      animation: fadeUp .4s ease forwards
    }

    .card-ex:nth-child(1) {
      animation-delay: .04s
    }

    .card-ex:nth-child(2) {
      animation-delay: .09s
    }

    .card-ex:nth-child(3) {
      animation-delay: .14s
    }

    .card-ex:nth-child(4) {
      animation-delay: .19s
    }

    .card-ex:nth-child(5) {
      animation-delay: .24s
    }

    .card-ex:nth-child(6) {
      animation-delay: .29s
    }

    .recommend-box {
      background: linear-gradient(135deg, var(--azul), var(--azul-m));
      color: #fff;
      border-radius: var(--r);
      padding: 16px 20px;
      margin-bottom: 16px;
    }

    .recommend-box small {
      font-size: 11px;
      opacity: .7;
      text-transform: uppercase;
      letter-spacing: 1px
    }

    .recommend-box p {
      font-size: 14px;
      margin-top: 4px;
      font-weight: 600
    }

    /* ═══════════════════════════════════════════
   PROGRESS SCREEN
═══════════════════════════════════════════ */
    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px
    }

    .stat-chip {
      background: var(--blanco);
      border: 1px solid var(--borde);
      border-radius: var(--r);
      padding: 16px;
      text-align: center
    }

    .stat-val {
      font-size: 1.8rem;
      font-weight: 900;
      color: var(--azul);
      display: block
    }

    .stat-lbl {
      font-size: 11px;
      color: var(--txt2);
      margin-top: 2px
    }

    .cal-week {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 6px;
      margin: 14px 0
    }

    .cal-day {
      border-radius: 50%;
      border: 2px solid var(--borde);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 700;
      color: var(--txt2);
      aspect-ratio: 1
    }

    .cal-day.active {
      background: var(--verde);
      border-color: var(--verde);
      color: #fff;
      box-shadow: 0 3px 10px rgba(91, 158, 58, .3)
    }

    /* em-hist-grid styles defined in server/teacher section below */
    #emotion-chart {
      width: 100%;
      height: 160px;
      border-radius: var(--rs);
      background: var(--blanco);
      display: block
    }

    /* ═══════════════════════════════════════════
   LOGROS
═══════════════════════════════════════════ */
    .logro-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px;
      border-radius: var(--rs);
      border: 1.5px solid var(--borde);
      background: var(--blanco);
      margin-bottom: 10px;
      transition: all .2s
    }

    .logro-item.unlocked {
      background: linear-gradient(135deg, rgba(91, 158, 58, .06), rgba(242, 169, 0, .06));
      border-color: var(--verde)
    }

    .logro-item.locked {
      opacity: .55
    }

    .logro-icon {
      font-size: 2rem;
      min-width: 42px;
      text-align: center
    }

    .logro-title {
      font-weight: 700;
      font-size: 14px
    }

    .logro-desc {
      font-size: 12px;
      color: var(--txt2)
    }

    /* ═══════════════════════════════════════════
   TEACHER LOCAL PANEL
═══════════════════════════════════════════ */
    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px
    }

    .data-table th {
      background: var(--azul);
      color: #fff;
      padding: 10px 12px;
      text-align: left;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .5px
    }

    .data-table td {
      border-bottom: 1px solid var(--borde);
      padding: 10px 12px
    }

    .data-table tr:last-child td {
      border: none
    }

    .data-table tr:hover td {
      background: var(--fondo)
    }

    .table-wrap {
      overflow-x: auto;
      border-radius: var(--rs);
      border: 1px solid var(--borde);
      box-shadow: var(--sombra)
    }

    .gal-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 10px
    }

    .gal-item {
      border-radius: var(--rs);
      overflow: hidden;
      box-shadow: var(--sombra);
      cursor: pointer;
      transition: transform .2s;
      border: 1px solid var(--borde)
    }

    .gal-item:hover {
      transform: scale(1.03)
    }

    .gal-item img {
      width: 100%;
      height: 110px;
      object-fit: cover
    }

    .gal-info {
      padding: 8px;
      font-size: 11px;
      background: var(--blanco)
    }

    .gal-name {
      font-weight: 700;
      color: var(--azul);
      margin-bottom: 2px
    }

    /* ═══════════════════════════════════════════
   UPLOAD AREA
═══════════════════════════════════════════ */
    .upload-area {
      border: 2px dashed var(--azul-c);
      border-radius: var(--r);
      padding: 22px;
      text-align: center;
      cursor: pointer;
      transition: background .2s;
      background: rgba(0, 119, 200, .03)
    }

    .upload-area:hover {
      background: rgba(0, 119, 200, .07)
    }

    .upload-area input[type=file] {
      display: none
    }

    .upload-preview {
      width: 100%;
      border-radius: var(--rs);
      margin-top: 12px;
      display: none;
      max-height: 200px;
      object-fit: cover
    }

    /* ═══════════════════════════════════════════
   SYNC BLOCK (STUDENT)
═══════════════════════════════════════════ */
    .sync-block {
      background: linear-gradient(135deg, #0d1f3c, var(--azul) 70%, var(--azul-m));
      border-radius: var(--r);
      padding: 22px;
      margin-bottom: 16px;
      border: 1px solid rgba(255, 255, 255, .08);
    }

    .sync-block-head {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 6px
    }

    .sync-block-head strong {
      color: #fff;
      font-size: 15px
    }

    #sync-chip {
      margin-left: auto;
      border-radius: var(--rp);
      padding: 4px 12px;
      font-size: 11px;
      font-weight: 800;
      background: rgba(255, 255, 255, .12);
      color: rgba(255, 255, 255, .75)
    }

    .sync-desc {
      font-size: 12px;
      color: rgba(255, 255, 255, .55);
      margin-bottom: 16px;
      line-height: 1.5
    }

    .sbtn {
      width: 100%;
      padding: 13px 18px;
      margin-bottom: 10px;
      border: none;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: transform .12s, filter .15s
    }

    .sbtn:active {
      transform: scale(.97)
    }

    .sbtn:last-child {
      margin-bottom: 0
    }

    .sbtn-green {
      background: linear-gradient(135deg, #1e8449, #27ae60);
      color: #fff;
      box-shadow: 0 4px 14px rgba(39, 174, 96, .35)
    }

    .sbtn-green:hover {
      filter: brightness(1.08)
    }

    .sbtn-mid {
      background: rgba(255, 255, 255, .1);
      color: #fff
    }

    .sbtn-mid:hover {
      background: rgba(255, 255, 255, .17)
    }

    .sbtn-sm {
      background: rgba(255, 255, 255, .05);
      color: rgba(255, 255, 255, .6);
      font-size: 13px;
      padding: 11px
    }

    .sbtn-sm:hover {
      background: rgba(255, 255, 255, .1)
    }

    .sbtn:disabled {
      opacity: .4;
      cursor: not-allowed;
      transform: none
    }

    .sync-url-row {
      margin-top: 12px;
      font-size: 11px;
      color: rgba(255, 255, 255, .35);
      text-align: center
    }

    .sync-url-row button {
      background: none;
      border: none;
      color: #79c0ff;
      cursor: pointer;
      font-size: 11px;
      font-weight: 700;
      text-decoration: underline
    }

    /* ═══════════════════════════════════════════
   MISC
═══════════════════════════════════════════ */
    .divider {
      height: 1px;
      background: var(--borde);
      margin: 20px 0
    }

    .section-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--azul);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px
    }

    .instr-box {
      background: var(--crema);
      border-left: 4px solid var(--salvia);
      border-radius: 0 var(--rs) var(--rs) 0;
      padding: 14px 16px;
      margin-bottom: 14px;
      font-size: 14px
    }

    .grounding-step {
      border-left: 4px solid var(--azul-c);
      padding: 10px 14px;
      margin-bottom: 10px;
      background: var(--blanco);
      border-radius: 0 var(--rs) var(--rs) 0;
      border: 1px solid var(--borde);
      border-left-width: 4px
    }

    .grounding-step .step-label {
      font-weight: 700;
      font-size: 13px;
      color: var(--azul);
      margin-bottom: 4px
    }

    .alert-support {
      background: linear-gradient(135deg, #FFF8E1, #FFEAA7);
      border: 2px solid var(--amarillo);
      border-radius: var(--r);
      padding: 14px 16px;
      margin-bottom: 14px;
      display: none
    }

    .alert-support.show {
      display: block
    }

    .download-hint {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      color: var(--verde);
      font-weight: 700;
      background: rgba(91, 158, 58, .1);
      border-radius: var(--rp);
      padding: 4px 12px;
      margin-top: 8px
    }

    .btn-stop {
      display: block;
      text-align: center;
      font-size: 13px;
      color: var(--terra);
      background: transparent;
      border: none;
      cursor: pointer;
      padding: 10px;
      width: 100%;
      font-weight: 700
    }

    /* ═══════════════════════════════════════════
   EJERCICIO — PANTALLA INMERSIVA
═══════════════════════════════════════════ */
    /* Cabecera de ejercicio */
    .ex-header {
      background: linear-gradient(135deg, var(--azul) 0%, var(--azul-m) 60%, var(--azul-c) 100%);
      border-radius: var(--r) var(--r) 0 0;
      padding: 28px 24px 22px;
      color: #fff;
      position: relative;
      overflow: hidden;
    }

    .ex-header::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% 20%, rgba(242, 169, 0, .18) 0%, transparent 50%),
        radial-gradient(circle at 10% 80%, rgba(255, 255, 255, .08) 0%, transparent 40%)
    }

    .ex-header-back {
      background: rgba(255, 255, 255, .15);
      border: 1px solid rgba(255, 255, 255, .25);
      color: #fff;
      border-radius: var(--rp);
      padding: 6px 14px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: background .2s;
      position: relative;
      z-index: 1
    }

    .ex-header-back:hover {
      background: rgba(255, 255, 255, .25)
    }

    .ex-header-body {
      position: relative;
      z-index: 1;
      margin-top: 16px
    }

    .ex-header-icon {
      font-size: 3rem;
      display: block;
      margin-bottom: 8px;
      filter: drop-shadow(0 4px 8px rgba(0, 0, 0, .2))
    }

    .ex-header-title {
      font-family: 'Lora', serif;
      font-size: 1.4rem;
      font-weight: 600;
      margin-bottom: 4px
    }

    .ex-header-meta {
      font-size: 12px;
      opacity: .75;
      display: flex;
      gap: 12px;
      flex-wrap: wrap
    }

    .ex-header-meta span {
      display: flex;
      align-items: center;
      gap: 4px
    }

    /* Badge proceso ACT */
    .ex-process-badge {
      display: inline-block;
      background: rgba(242, 169, 0, .28);
      color: var(--amarillo);
      border-radius: var(--rp);
      padding: 3px 10px;
      font-size: 11px;
      font-weight: 800;
      border: 1px solid rgba(242, 169, 0, .35);
      margin-top: 10px;
      letter-spacing: .3px;
    }

    /* Barra de progreso del ejercicio */
    .ex-progress-wrap {
      background: rgba(255, 255, 255, .12);
      height: 4px;
      border-radius: var(--rp);
      margin-top: 14px;
      overflow: hidden
    }

    .ex-progress-fill {
      height: 100%;
      background: var(--amarillo);
      border-radius: var(--rp);
      transition: width .5s ease;
      width: 0%
    }

    /* Sección intro/contexto */
    .ex-context {
      background: var(--crema);
      border-radius: 0 0 0 0;
      border-left: none;
      padding: 20px 22px;
      margin: 0;
      border-top: 3px solid var(--amarillo);
    }

    .ex-context-quote {
      font-family: 'Lora', serif;
      font-size: 1.05rem;
      color: var(--azul);
      font-style: italic;
      line-height: 1.65;
      margin-bottom: 10px;
    }

    .ex-context-instr {
      font-size: 13px;
      color: var(--txt2);
      line-height: 1.6
    }

    /* Pasos / fases del ejercicio */
    .ex-body {
      background: var(--blanco);
      border-radius: 0 0 var(--r) var(--r);
      padding: 22px;
      border: 1px solid var(--borde);
      border-top: none;
      margin-bottom: 14px
    }

    .ex-step {
      background: var(--fondo);
      border-radius: 12px;
      padding: 18px;
      margin-bottom: 14px;
      border: 1.5px solid var(--borde);
      transition: border-color .2s, box-shadow .2s;
    }

    .ex-step:focus-within {
      border-color: var(--azul-c);
      box-shadow: 0 0 0 3px rgba(0, 119, 200, .08)
    }

    .ex-step-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      background: var(--azul);
      color: #fff;
      border-radius: 50%;
      font-size: 11px;
      font-weight: 900;
      margin-bottom: 8px;
      flex-shrink: 0;
    }

    .ex-step-label {
      font-weight: 800;
      font-size: 13px;
      color: var(--azul);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px
    }

    .ex-step textarea,
    .ex-step input[type=text] {
      width: 100%;
      padding: 12px;
      border: 1.5px solid var(--borde);
      border-radius: var(--rs);
      font-size: 14px;
      font-family: inherit;
      background: var(--blanco);
      color: var(--txt);
      resize: vertical;
      transition: border-color .2s, box-shadow .2s;
    }

    .ex-step textarea:focus,
    .ex-step input:focus {
      outline: none;
      border-color: var(--azul-c);
      box-shadow: 0 0 0 3px rgba(0, 119, 200, .1)
    }

    .ex-step .char-c {
      text-align: right;
      font-size: 10px;
      color: var(--txt2);
      margin-top: 4px
    }

    .ex-step .char-c.ok {
      color: var(--verde)
    }

    .ex-step .char-c.warn {
      color: var(--terra)
    }

    /* Animación de respiración - mejorada */
    .breathe-card {
      background: linear-gradient(135deg, #081a2e, var(--azul));
      border-radius: var(--r);
      padding: 30px 20px;
      text-align: center;
      margin-bottom: 14px;
      color: #fff
    }

    .breathe-card h4 {
      font-family: 'Lora', serif;
      font-size: 1rem;
      margin-bottom: 4px;
      opacity: .8
    }

    .breathe-card p {
      font-size: 12px;
      opacity: .6;
      margin-bottom: 24px
    }

    .breathe-outer {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      margin: 0 auto 20px;
      background: rgba(255, 255, 255, .05);
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1.5px solid rgba(255, 255, 255, .12);
      position: relative;
    }

    .breathe-ring {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(242, 169, 0, .35) 0%, rgba(0, 119, 200, .4) 60%, transparent 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: breatheCycle 8s ease-in-out infinite;
      box-shadow: 0 0 30px rgba(242, 169, 0, .2);
    }

    @keyframes breatheCycle {

      0%,
      100% {
        transform: scale(.7);
        opacity: .7
      }

      25% {
        transform: scale(1.05);
        opacity: 1
      }

      50% {
        transform: scale(1);
        opacity: .9
      }

      75% {
        transform: scale(.75);
        opacity: .7
      }
    }

    .breathe-inner-text {
      font-size: 12px;
      font-weight: 700;
      color: #fff;
      text-align: center;
      line-height: 1.3
    }

    .breathe-phase {
      font-size: 15px;
      font-weight: 800;
      margin-bottom: 2px
    }

    .breathe-count {
      font-size: 22px;
      font-weight: 900;
      color: var(--amarillo)
    }

    .breathe-steps {
      display: flex;
      justify-content: center;
      gap: 10px;
      font-size: 11px;
      opacity: .6
    }

    .breathe-steps span {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2px
    }

    .breathe-steps strong {
      font-size: 13px;
      color: var(--amarillo);
      font-weight: 900
    }

    /* Grilla de valores */
    .valores-instruccion {
      font-size: 13px;
      color: var(--txt2);
      margin-bottom: 12px;
      line-height: 1.5
    }

    .valores-count {
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      color: var(--azul);
      margin-bottom: 12px
    }

    .grid-auto {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 8px
    }

    .valor-chip {
      border: 2px solid var(--borde);
      border-radius: 10px;
      padding: 10px 10px 8px;
      cursor: pointer;
      text-align: center;
      background: var(--blanco);
      font-size: 13px;
      font-weight: 700;
      transition: all .2s;
      color: var(--txt);
      user-select: none;
    }

    .valor-chip:hover {
      border-color: var(--azul-c);
      background: rgba(0, 119, 200, .04)
    }

    .valor-chip.selected {
      background: linear-gradient(145deg, var(--azul), var(--azul-m));
      border-color: var(--azul);
      color: #fff;
      transform: scale(1.04);
      box-shadow: 0 4px 14px rgba(0, 59, 113, .25);
    }

    /* Cierre del ejercicio */
    .ex-close-card {
      background: var(--blanco);
      border: 1.5px solid var(--borde);
      border-radius: var(--r);
      padding: 20px;
      margin-bottom: 14px
    }

    .ex-close-card h4 {
      font-family: 'Lora', serif;
      font-size: 1rem;
      color: var(--azul);
      margin-bottom: 14px
    }

    /* Rating stars visual */
    .rating-wrap {
      display: flex;
      align-items: center;
      gap: 12px
    }

    .rating-wrap input[type=range] {
      flex: 1;
      accent-color: var(--azul-c);
      height: 4px
    }

    .rating-badge {
      min-width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--azul);
      color: #fff;
      font-weight: 900;
      font-size: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform .2s, background .2s;
      box-shadow: 0 2px 8px rgba(0, 59, 113, .25);
    }

    .rating-badge.good {
      background: var(--verde)
    }

    .rating-badge.great {
      background: linear-gradient(135deg, var(--verde), var(--amarillo))
    }

    .rating-desc {
      font-size: 11px;
      color: var(--txt2);
      text-align: right;
      margin-top: 4px;
      font-style: italic
    }

    /* Upload mejorado */
    .upload-zone {
      border: 2px dashed var(--azul-c);
      border-radius: var(--r);
      padding: 24px;
      text-align: center;
      cursor: pointer;
      transition: background .2s, border-color .2s;
      background: rgba(0, 119, 200, .03);
    }

    .upload-zone:hover {
      background: rgba(0, 119, 200, .07);
      border-color: var(--azul)
    }

    .upload-zone input[type=file] {
      display: none
    }

    .upload-zone-icon {
      font-size: 2rem;
      margin-bottom: 6px
    }

    .upload-zone-text {
      font-size: 13px;
      color: var(--txt2);
      margin-bottom: 3px
    }

    .upload-zone-meta {
      font-size: 11px;
      color: var(--txt2);
      opacity: .7
    }

    .upload-preview-wrap {
      margin-top: 12px;
      position: relative
    }

    .upload-preview-img {
      width: 100%;
      border-radius: var(--rs);
      max-height: 220px;
      object-fit: cover;
      display: none
    }

    .upload-preview-tag {
      display: none;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      color: var(--verde);
      font-weight: 700;
      background: rgba(91, 158, 58, .1);
      border-radius: var(--rp);
      padding: 4px 12px;
      margin-top: 8px
    }

    /* Botón guardar grande */
    .btn-save-ex {
      width: 100%;
      padding: 17px;
      background: linear-gradient(135deg, var(--verde), #45a029);
      color: #fff;
      border: none;
      border-radius: var(--r);
      font-size: 16px;
      font-weight: 900;
      cursor: pointer;
      transition: transform .15s, box-shadow .2s, filter .2s;
      box-shadow: 0 4px 18px rgba(91, 158, 58, .4);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .btn-save-ex:hover {
      filter: brightness(1.08);
      transform: translateY(-1px);
      box-shadow: 0 6px 22px rgba(91, 158, 58, .5)
    }

    .btn-save-ex:active {
      transform: scale(.98)
    }

    .btn-save-ex:disabled {
      opacity: .5;
      cursor: not-allowed;
      transform: none;
      box-shadow: none
    }

    .btn-stop-ex {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      width: 100%;
      padding: 13px;
      background: transparent;
      color: var(--terra);
      border: 1.5px solid rgba(201, 130, 90, .35);
      border-radius: var(--r);
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 8px;
      transition: background .2s;
    }

    .btn-stop-ex:hover {
      background: rgba(201, 130, 90, .06)
    }

    @keyframes celebrate {
      0% {
        transform: scale(1)
      }

      40% {
        transform: scale(1.08);
        filter: brightness(1.2)
      }

      100% {
        transform: scale(1)
      }
    }

    .celebrating {
      animation: celebrate .6s ease forwards
    }

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .5);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      padding: 16px
    }

    .modal-overlay.show {
      display: flex
    }

    .modal-box {
      background: var(--blanco);
      border-radius: var(--r);
      padding: 28px;
      width: min(100%, 440px);
      box-shadow: 0 24px 64px rgba(0, 0, 0, .25);
      animation: fadeUp .25s ease;
      position: relative
    }

    .modal-title {
      font-family: 'Lora', serif;
      font-size: 1.15rem;
      margin-bottom: 10px;
      color: var(--azul)
    }

    .modal-img {
      width: 100%;
      border-radius: var(--rs);
      margin: 12px 0;
      max-height: 300px;
      object-fit: contain
    }

    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--azul);
      color: #fff;
      border-radius: var(--rp);
      padding: 11px 22px;
      font-size: 14px;
      font-weight: 700;
      z-index: 99999;
      animation: toastIn .3s ease, toastOut .4s 2.6s forwards;
      white-space: nowrap;
      box-shadow: 0 4px 20px rgba(0, 59, 113, .4)
    }

    @keyframes toastIn {
      from {
        opacity: 0;
        transform: translateX(-50%) translateY(12px)
      }

      to {
        opacity: 1;
        transform: translateX(-50%) translateY(0)
      }
    }

    @keyframes toastOut {
      to {
        opacity: 0;
        transform: translateX(-50%) translateY(8px)
      }
    }

    /* ═══════════════════════════════════════════
   SERVER MODE — PANEL DOCENTE ONLINE
═══════════════════════════════════════════ */
    #server-mode {
      display: none;
      min-height: 100vh;
      background: #0d1117;
      color: #c9d1d9;
      font-family: 'Nunito', sans-serif
    }

    /* Header */
    .srv-hdr {
      background: #161b22;
      border-bottom: 1px solid #21262d;
      padding: 0 28px;
      height: 64px;
      display: flex;
      align-items: center;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .srv-hdr-logo {
      display: flex;
      align-items: center;
      gap: 10px
    }

    .srv-hdr-badge {
      background: var(--amarillo);
      color: var(--azul);
      font-weight: 900;
      font-size: 12px;
      border-radius: 6px;
      padding: 3px 8px
    }

    .srv-hdr-name {
      font-family: 'Lora', serif;
      font-size: 16px;
      font-weight: 600;
      color: #e6edf3
    }

    .srv-hdr-tag {
      font-size: 12px;
      color: #8b949e;
      font-weight: 400
    }

    .srv-hdr-actions {
      margin-left: auto;
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap
    }

    .sb {
      background: #238636;
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 7px 16px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: filter .15s
    }

    .sb:hover {
      filter: brightness(1.12)
    }

    .sb.blue {
      background: #1f6feb
    }

    .sb.g {
      background: transparent;
      color: #58a6ff;
      border: 1px solid #30363d
    }

    .sb.g:hover {
      background: rgba(88, 166, 255, .08)
    }

    .sb.del {
      background: #b91c1c
    }

    /* Main layout */
    .srv-main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 28px 24px
    }

    /* PIN screen */
    .srv-pin-screen {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: #0d1117;
      padding: 20px
    }

    .srv-pin-box {
      background: #161b22;
      border: 1px solid #21262d;
      border-radius: 16px;
      padding: 48px 40px;
      width: min(100%, 400px);
      text-align: center
    }

    .srv-pin-box h2 {
      font-family: 'Lora', serif;
      font-size: 1.5rem;
      color: #e6edf3;
      margin-bottom: 8px
    }

    .srv-pin-box p {
      font-size: 13px;
      color: #8b949e;
      margin-bottom: 28px
    }

    .srv-pin-inp {
      width: 100%;
      background: rgba(255, 255, 255, .05);
      border: 1.5px solid #30363d;
      border-radius: 8px;
      padding: 14px 16px;
      font-size: 18px;
      color: #e6edf3;
      text-align: center;
      letter-spacing: 6px;
      margin-bottom: 14px;
      font-family: inherit;
      transition: border-color .2s;
    }

    .srv-pin-inp:focus {
      outline: none;
      border-color: #58a6ff
    }

    .srv-pin-btn {
      width: 100%;
      background: #238636;
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 14px;
      font-size: 16px;
      font-weight: 800;
      cursor: pointer;
      transition: filter .15s
    }

    .srv-pin-btn:hover {
      filter: brightness(1.1)
    }

    /* Import zone — THE KEY ELEMENT */
    .srv-import-zone {
      background: linear-gradient(135deg, #0d2137 0%, #003B71 55%, #005DA4 100%);
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 28px;
      border: 1px solid rgba(255, 255, 255, .08);
    }

    .srv-import-zone h2 {
      font-family: 'Lora', serif;
      color: #fff;
      font-size: 1.35rem;
      margin-bottom: 6px
    }

    .srv-import-zone p {
      font-size: 13px;
      color: rgba(255, 255, 255, .5);
      margin-bottom: 22px
    }

    .srv-import-btns {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-bottom: 14px
    }

    .srv-import-btn-main {
      flex: 1;
      min-width: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 18px 24px;
      background: linear-gradient(135deg, var(--amarillo), #e09500);
      color: var(--azul);
      border-radius: 12px;
      font-size: 16px;
      font-weight: 900;
      cursor: pointer;
      box-shadow: 0 6px 20px rgba(242, 169, 0, .4);
      transition: transform .15s, box-shadow .2s;
      border: none;
    }

    .srv-import-btn-main:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 26px rgba(242, 169, 0, .5)
    }

    .srv-import-btn-main:active {
      transform: scale(.97)
    }

    .srv-drop-zone {
      flex: 1;
      min-width: 160px;
      border: 2px dashed rgba(255, 255, 255, .2);
      border-radius: 12px;
      padding: 18px;
      text-align: center;
      cursor: pointer;
      background: rgba(255, 255, 255, .03);
      transition: border-color .2s, background .2s;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }

    .srv-drop-zone:hover,
    .srv-drop-zone.over {
      border-color: var(--amarillo);
      background: rgba(242, 169, 0, .06)
    }

    .srv-drop-zone span {
      color: rgba(255, 255, 255, .45);
      font-size: 13px
    }

    #srv-load-st {
      margin-top: 14px
    }

    .srv-json-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 12px;
      font-size: 12px;
      color: rgba(255, 255, 255, .35)
    }

    #srv-jc {
      color: var(--amarillo);
      font-weight: 900;
      font-size: 15px
    }

    .srv-add-more {
      background: rgba(255, 255, 255, .1);
      border: 1px solid rgba(255, 255, 255, .18);
      color: #fff;
      border-radius: 8px;
      padding: 5px 14px;
      font-size: 12px;
      cursor: pointer;
      font-weight: 700
    }

    /* Stats */
    .srv-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 14px;
      margin-bottom: 24px
    }

    .srv-stat {
      background: #161b22;
      border: 1px solid #21262d;
      border-radius: 12px;
      padding: 18px;
      text-align: center
    }

    .srv-stat .sv {
      font-size: 2rem;
      font-weight: 900;
      color: #58a6ff;
      display: block;
      line-height: 1
    }

    .srv-stat .sl {
      font-size: 11px;
      color: #8b949e;
      margin-top: 4px;
      text-transform: uppercase;
      letter-spacing: .5px
    }

    /* Sections */
    .srv-sec {
      background: #161b22;
      border: 1px solid #21262d;
      border-radius: 12px;
      padding: 22px;
      margin-bottom: 20px
    }

    .srv-sec h3 {
      font-size: 15px;
      font-weight: 700;
      color: #e6edf3;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px
    }

    .srv-sec h3 .cnt {
      font-size: 12px;
      color: #8b949e;
      font-weight: 400;
      margin-left: 4px
    }

    /* Table */
    .srv-tbl-wrap {
      overflow-x: auto;
      border-radius: 8px;
      border: 1px solid #21262d
    }

    .srv-tbl {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px
    }

    .srv-tbl th {
      background: rgba(88, 166, 255, .08);
      color: #58a6ff;
      padding: 11px 14px;
      text-align: left;
      font-weight: 700;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .4px;
      white-space: nowrap
    }

    .srv-tbl td {
      padding: 11px 14px;
      border-bottom: 1px solid #21262d;
      color: #c9d1d9;
      vertical-align: middle
    }

    .srv-tbl tr:last-child td {
      border: none
    }

    .srv-tbl tr:hover td {
      background: rgba(255, 255, 255, .02)
    }

    /* Alerts */
    .srv-alert {
      border-radius: 8px;
      padding: 12px 16px;
      margin-bottom: 10px;
      font-size: 13px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px
    }

    .srv-alert.ok {
      background: rgba(35, 134, 54, .15);
      color: #56d364;
      border: 1px solid rgba(35, 134, 54, .3)
    }

    .srv-alert.err {
      background: rgba(248, 81, 73, .15);
      color: #ff7b72;
      border: 1px solid rgba(248, 81, 73, .3)
    }

    .srv-alert.warn {
      background: rgba(210, 153, 34, .15);
      color: #e3b341;
      border: 1px solid rgba(210, 153, 34, .3)
    }

    .srv-alert.info {
      background: rgba(88, 166, 255, .1);
      color: #58a6ff;
      border: 1px solid rgba(88, 166, 255, .2)
    }

    /* Gallery */
    .srv-gal {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 12px
    }

    .srv-gi {
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid #21262d;
      cursor: pointer;
      transition: transform .2s
    }

    .srv-gi:hover {
      transform: scale(1.03)
    }

    .srv-gi img {
      width: 100%;
      height: 120px;
      object-fit: cover
    }

    .srv-gi .gi {
      padding: 10px;
      background: #161b22
    }

    .srv-gi .gin {
      font-weight: 700;
      color: #e6edf3;
      font-size: 12px
    }

    .srv-gi .gis {
      font-size: 11px;
      color: #8b949e;
      margin-top: 2px
    }

    /* emotion history (dark) — server panel */
    .srv-em-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 14px
    }

    .srv-em-pill {
      background: rgba(255, 255, 255, .05);
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: 12px;
      padding: 18px 12px 16px;
      text-align: center;
      transition: background .2s, transform .2s;
    }

    .srv-em-pill:hover {
      background: rgba(88, 166, 255, .1);
      transform: translateY(-2px)
    }

    .srv-em-pill .epi {
      font-size: 2rem;
      display: block;
      margin-bottom: 8px;
      line-height: 1
    }

    .srv-em-pill .epn {
      font-weight: 700;
      color: #c9d1d9;
      font-size: 12px;
      margin-bottom: 6px;
      display: block
    }

    .srv-em-pill .epc {
      font-size: 18px;
      font-weight: 900;
      color: #58a6ff;
      background: rgba(88, 166, 255, .12);
      border-radius: 20px;
      padding: 2px 12px;
      display: inline-block;
    }

    /* emotion history (light) — teacher local panel */
    .em-hist-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 12px;
      margin-top: 12px
    }

    .em-hist-pill {
      background: var(--blanco);
      border-radius: 12px;
      padding: 16px 10px 14px;
      text-align: center;
      border: 1px solid var(--borde);
      box-shadow: var(--sombra);
      transition: box-shadow .2s, transform .2s;
    }

    .em-hist-pill:hover {
      box-shadow: var(--sombra-lg);
      transform: translateY(-2px)
    }

    .em-hist-pill .ehi {
      font-size: 2rem;
      display: block;
      margin-bottom: 8px;
      line-height: 1
    }

    .em-hist-pill .ehn {
      font-weight: 700;
      color: var(--azul);
      font-size: 12px;
      margin-bottom: 6px;
      display: block
    }

    .em-hist-pill .ehc {
      font-size: 18px;
      font-weight: 900;
      color: var(--azul-c);
      background: rgba(0, 119, 200, .1);
      border-radius: 20px;
      padding: 2px 12px;
      display: inline-block;
    }

    /* Reflexiones */
    .srv-ref-item {
      padding: 16px;
      background: rgba(255, 255, 255, .02);
      border: 1px solid #21262d;
      border-radius: 10px;
      margin-bottom: 12px
    }

    .srv-ref-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px
    }

    .srv-ref-name {
      font-weight: 700;
      color: #e6edf3;
      font-size: 14px
    }

    .srv-ref-date {
      font-size: 11px;
      color: #8b949e
    }

    .srv-ref-title {
      font-size: 14px;
      font-weight: 700;
      color: #58a6ff;
      margin-bottom: 4px
    }

    .srv-ref-text {
      font-size: 13px;
      color: #8b949e;
      font-style: italic;
      line-height: 1.5
    }

    /* ═══════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════ */
    @media(prefers-reduced-motion:reduce) {

      *,
      *::before,
      *::after {
        animation: none !important;
        transition: none !important
      }

      .card-ex {
        opacity: 1 !important
      }
    }

    @media(max-width:600px) {
      .stu-app {
        padding: 16px 12px 90px
      }

      .srv-main {
        padding: 16px 14px
      }

      .srv-hdr {
        padding: 0 16px
      }

      .srv-hdr-actions {
        gap: 6px
      }

      .sb {
        padding: 6px 10px;
        font-size: 12px
      }

      .srv-import-btns {
        flex-direction: column
      }

      .srv-import-btn-main {
        padding: 16px
      }

      .banner {
        height: 150px
      }

      .banner-title {
        font-size: 1.3rem
      }

      .streak-num {
        font-size: 1.8rem
      }

      .srv-stats {
        grid-template-columns: repeat(3, 1fr)
      }
    }

    @media(min-width:768px) {
      .stu-app {
        padding: 28px 24px 100px
      }

      .ex-grid {
        grid-template-columns: repeat(3, 1fr)
      }

      .stats-grid {
        grid-template-columns: repeat(4, 1fr)
      }
    }

    @media(min-width:1024px) {
      .srv-import-btns {
        flex-wrap: nowrap
      }
    }
  </style>
</head>

<body>

  <!-- ═════════════ CONNECTIVITY BAR ═════════════ -->
  <div id="conn-bar" role="status" aria-live="polite">
    <span class="conn-dot"></span>
    <span id="conn-msg">Verificando conexión…</span>
    <button class="conn-btn" onclick="doManualSync()">⬆ Sync</button>
  </div>

  <!-- ═══════════════════════════════════════════
     MODO SERVIDOR (?mode=server)
     PIN + Panel docente completo
═══════════════════════════════════════════ -->
  <div id="server-mode" style="display:none">

    <!-- PIN -->
    <div id="srv-pin-screen" class="srv-pin-screen">
      <div class="srv-pin-box">
        <div style="font-size:3.5rem;margin-bottom:18px">🔐</div>
        <h2>Panel Docente</h2>
        <p>ACTiva Arte · UNAD<br>Ingresa el PIN de acceso para continuar</p>
        <input type="password" id="srv-pin" class="srv-pin-inp" placeholder="PIN" maxlength="20" autofocus>
        <div id="srv-pin-err" style="color:#ff7b72;font-size:13px;margin-bottom:12px;display:none">⚠️ PIN incorrecto
        </div>
        <button onclick="checkSrvPin()" class="srv-pin-btn">Acceder al panel →</button>
