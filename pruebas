    function buildEmotionTrends(sesiones) {
      const container = document.getElementById('emotion-trends');
      if (!container) return;

      // Contar emociones de los últimos 30 días (incluyendo multi-selección)
      const cutoff = new Date(); cutoff.setDate(cutoff.getDate() - 30);
      let pos = 0, neu = 0, neg = 0, total = 0;
      sesiones.forEach(s => {
        if (new Date(s.fecha) < cutoff) return;
        const ids = Array.isArray(s.emocionesInicio) && s.emocionesInicio.length
          ? s.emocionesInicio
          : (s.emocionInicio ? [s.emocionInicio] : []);
        ids.forEach(id => {
          const em = EMOTIONS.find(e => e.id === id);
          if (!em) return;
          total++;
          if (em.valencia === 'positiva') pos++;
          else if (em.valencia === 'neutral') neu++;
          else if (em.valencia === 'negativa') neg++;
        });
      });

      if (total === 0) {
        container.innerHTML = '<p style="font-size:13px;color:var(--txt2);">Aún no hay datos suficientes para mostrar tendencias.</p>';
        return;
      }

      const pct = (n) => Math.round((n / total) * 100);
      const bars = [
        { label: 'Positivas 😊', pct: pct(pos), color: 'var(--verde)', count: pos },
        { label: 'Neutrales 😐', pct: pct(neu), color: 'var(--amarillo)', count: neu },
        { label: 'Negativas 😔', pct: pct(neg), color: 'var(--azul-c)', count: neg }
      ];

      container.innerHTML = `<p style="font-size:12px;color:var(--txt2);margin-bottom:14px;">Basado en ${total} registro(s) del último mes.</p>`
