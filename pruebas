    }

    function migrateIfNeeded() {
      const legacyKeys = ['activa_users_v3', 'activa_users_v4', 'activa_users_v5'];
      let currentData = localStorage.getItem(STORAGE_KEY);
      if (!currentData) {
        for (let key of legacyKeys) {
          const legacy = localStorage.getItem(key);
          if (legacy) {
            try {
              let data = JSON.parse(legacy);
              data.usuarios.forEach(u => {
                if (u.consent === undefined) u.consent = false;
              });
              localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
              console.log('[ACTiva Arte v6] Data migrated from ' + key);
              break;
            } catch (e) { }
          }
        }
      }
    }

