    function connBar(t, m) { const b = document.getElementById('conn-bar'); if (!b) return; b.className = 'show ' + t; document.getElementById('conn-msg').textContent = m }
    function hideBar() { const b = document.getElementById('conn-bar'); if (b) b.classList.remove('show') }

    function updSync() {
      const p = gQ().length, u = gURL();
      const chip = document.getElementById('sync-chip');
      const desc = document.getElementById('sync-desc');
      const btn = document.getElementById('btn-sync');
      const lbl = document.getElementById('lbl-sync');
      const urlL = document.getElementById('srv-url-lbl');
      const pb = document.getElementById('pending-badge');
      if (chip) {
        if (_online && u) { chip.textContent = p > 0 ? '⬤ ' + p + ' pendiente' + (p > 1 ? 's' : '') : '✓ Sincronizado'; chip.style.cssText = p > 0 ? 'margin-left:auto;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700;background:rgba(242,169,0,.3);color:#F2A900' : 'margin-left:auto;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700;background:rgba(39,174,96,.3);color:#56d364' }
        else if (_online) { chip.textContent = '⬤ Online'; chip.style.cssText = 'margin-left:auto;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700;background:rgba(88,166,255,.2);color:#58a6ff' }
        else { chip.textContent = '⬤ Offline'; chip.style.cssText = 'margin-left:auto;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700;background:rgba(229,62,62,.2);color:#ff7b72' }
      }
      if (desc) {
        if (_online && u && p) desc.textContent = 'Tienes ' + p + ' sesión(es) sin sincronizar. Pulsa el botón verde.';
        else if (_online && u) desc.textContent = 'Todos tus datos están sincronizados con el servidor. ✓';
        else if (_online) desc.textContent = 'Conectado sin servidor. Exporta el JSON para entregárselo al docente.';
        else desc.textContent = 'Sin internet. Tus datos están guardados. Exporta el JSON cuando tengas señal.';
      }
      if (btn) { if (_online && u) { btn.style.display = 'flex'; btn.disabled = p === 0; btn.style.opacity = p ? '1' : '0.5'; if (lbl) lbl.textContent = p ? 'Sincronizar ahora (' + p + ' pend.)' : 'Ya sincronizado ✓' } else btn.style.display = 'none' }
      if (urlL) urlL.textContent = u ? 'Servidor: ' + u.slice(0, 40) + (u.length > 40 ? '…' : '') : 'Sin servidor configurado';
      if (pb) { pb.textContent = p; p > 0 ? pb.style.display = 'flex' : pb.style.display = 'none' }
