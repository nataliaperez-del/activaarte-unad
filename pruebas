        </div>
        <div class="upload-preview-wrap">
          <img id="upload-preview" class="upload-preview-img" alt="Vista previa">
          <div class="upload-preview-tag" id="upload-download-badge">✅ Imagen lista para guardar</div>
        </div>
      </div>

      <button class="btn-save-ex" id="save-exercise">
        <span>✓</span> Guardar y completar ejercicio
