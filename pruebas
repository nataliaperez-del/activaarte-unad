      } else if (emObjs.some(e => TRIAGE_RULES.aceptacion_presente.emociones.includes(e.id))) {
        matchRule = TRIAGE_RULES.aceptacion_presente;
      } else if (emObjs.some(e => TRIAGE_RULES.valores_accion.emociones.includes(e.id))) {
        matchRule = TRIAGE_RULES.valores_accion;
