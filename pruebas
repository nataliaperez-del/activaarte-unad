    function pseudoHash(str) {
      let hash = 0;
      for (let i = 0; i < str.length; i++) {
        hash = ((hash << 5) - hash) + str.charCodeAt(i);
        hash |= 0;
      }
      return 'ACT-' + Math.abs(hash).toString(36).toUpperCase();
    }

    function evaluateRisk(user) {
      if (!user || !user.sesiones || user.sesiones.length < 3) return;
      const last3 = user.sesiones.slice(-3);
      let riskScore = 0;
      last3.forEach(s => {
        const hasRiskEmotion = (s.emocionesInicio || []).some(id => ['ansioso', 'triste', 'enojado'].includes(id));
        const hFusion = (s.metricsPre?.fusion >= 8);
        const hEvitacion = (s.metricsPre?.evitacion >= 8);
        if (hasRiskEmotion || hFusion || hEvitacion) riskScore++;
      });

      if (riskScore >= 3) {
        showSupportEscalation();
      }
    }

