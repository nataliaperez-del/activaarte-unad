    function doManualSync() { if (!gURL()) { changeServerUrl(); return } if (!gQ().length) { toast('✓ Sin datos pendientes'); return } autoSync() }

    async function autoSync() {
      if (_syncing || !_online) return; const url = gURL(); if (!url) return; const pend = gQ(); if (!pend.length) return;
      _syncing = true; connBar('syncing', '🔄 Sincronizando…');
      try {
        const toSync = getUsers().usuarios.filter(u => pend.includes(u.id));
        const r = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'text/plain;charset=utf-8' }, body: JSON.stringify({ action: 'syncUsers', source: 'auto', version: APP_VER, timestamp: new Date().toISOString(), payload: { usuarios: toSync } }), mode: 'cors', signal: AbortSignal.timeout(15000) });
        if (r.ok) { clrQ(); connBar('online', '✅ Datos sincronizados'); toast('☁️ Sincronizado'); setTimeout(hideBar, 3500) }
        else connBar('offline', '⚠️ Error ' + r.status);
      } catch (e) { if (e.name !== 'AbortError') connBar('offline', '📴 Sin conexión') }
      finally { _syncing = false; updSync() }
    }

    function downloadApp() { const blob = new Blob([document.documentElement.outerHTML], { type: 'text/html;charset=utf-8' }); const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'ACTivaArte_UNAD_offline.html'; a.click(); URL.revokeObjectURL(a.href); toast('💾 App descargada') }

    function exportMyJson() {
      const user = getUserById(state.user?.id); if (!user) { toast('⚠️ Inicia sesión primero'); return }
      const publicId = pseudoHash(user.id + user.nombre);
      const exportedUser = JSON.parse(JSON.stringify(user));
      exportedUser.nombre = publicId; // Pseudonimización del JSON exportado
      const exp = { exportado_por: publicId, version: APP_VER, fecha_exportacion: new Date().toISOString(), usuarios: [exportedUser] };
      const blob = new Blob([JSON.stringify(exp, null, 2)], { type: 'application/json' }); const a = document.createElement('a');
      a.href = URL.createObjectURL(blob); a.download = 'ACTivaArte_' + publicId + '_' + new Date().toISOString().slice(0, 10) + '.json';
      a.click(); URL.revokeObjectURL(a.href); toast('📤 JSON privado exportado')
    }

    function changeServerUrl() { const c = gURL(); const u = prompt('URL del servidor (Google Apps Script):', c); if (u === null) return; localStorage.setItem(GAS_URL_KEY, u.trim()); updSync(); toast(u.trim() ? '🔗 Servidor configurado' : 'Sin servidor') }

    (function () { const _o = window.saveUser; window.saveUser = function (user) { _o(user); if (user && user.id) addQ(user.id) } })();

    /* ════════════════ MODO SERVIDOR ════════════════ */
    const IS_SRV = new URLSearchParams(location.search).get('mode') === 'server';
    let srvD = { usuarios: [], n: 0 };
    const saveSrv = () => { try { localStorage.setItem(SRV_KEY, JSON.stringify(srvD)) } catch { } };
    const loadSrv = () => { try { const d = JSON.parse(localStorage.getItem(SRV_KEY) || '{}'); srvD = { usuarios: d.usuarios || [], n: d.n || 0 } } catch { srvD = { usuarios: [], n: 0 } } };

    function srvMerge(u) {
      const idx = srvD.usuarios.findIndex(x => x.id === u.id || x.nombre.toLowerCase().trim() === u.nombre.toLowerCase().trim());
      if (idx === -1) { srvD.usuarios.push(u); return { nuevo: true, ses: (u.sesiones || []).length } }
      const ex = srvD.usuarios[idx]; const sids = new Set((ex.sesiones || []).map(s => s.id)); let ns = 0;
      (u.sesiones || []).forEach(s => { if (!sids.has(s.id)) { (ex.sesiones = ex.sesiones || []).push(s); ns++ } });
      ex.puntos = Math.max(ex.puntos || 0, u.puntos || 0);
      const ll = new Set(ex.logros || []); (u.logros || []).forEach(l => ll.add(l)); ex.logros = [...ll];
      srvD.usuarios[idx] = ex; return { nuevo: false, ses: ns }
    }

    function srvFile(file) {
      return new Promise((res, rej) => {
        const r = new FileReader(); r.onload = e => {
          try {
            const p = JSON.parse(e.target.result); if (!p.usuarios || !Array.isArray(p.usuarios)) throw new Error('Falta "usuarios"');
            let nu = 0, na = 0, ns = 0; p.usuarios.forEach(u => { const x = srvMerge(u); if (x) { if (x.nuevo) nu++; else na++; ns += x.ses } });
            srvD.n++; saveSrv(); res({ file: file.name, nu, na, ns })
          } catch (err) { rej({ file: file.name, err: err.message }) }
        }; r.onerror = () => rej({ file: file.name, err: 'Error lectura' }); r.readAsText(file, 'utf-8')
      })
    }

    async function srvLoad(files) {
      const st = document.getElementById('srv-load-st'); if (st) st.innerHTML = '<div class="srv-alert info">🔄 Procesando ' + files.length + ' archivo(s)…</div>';
      const res = await Promise.allSettled([...files].filter(f => f.name.endsWith('.json') || f.type === 'application/json').map(f => srvFile(f)));
      const ok = res.filter(r => r.status === 'fulfilled').map(r => r.value);
      const er = res.filter(r => r.status === 'rejected').map(r => r.reason);
      let html = '';
      if (ok.length) { const tn = ok.reduce((a, r) => a + r.nu, 0), ta = ok.reduce((a, r) => a + r.na, 0), ts = ok.reduce((a, r) => a + r.ns, 0); html += `<div class="srv-alert ok">✅ ${ok.length} archivo(s) · ${tn} nuevo(s) · ${ta} actualizado(s) · ${ts} sesión(es)</div>` }
      er.forEach(e => { html += `<div class="srv-alert err">❌ ${e.file}: ${e.err}</div>` });
      if (st) st.innerHTML = html; srvRender()
    }

    function srvRender() {
      const allS = srvD.usuarios.flatMap(u => u.sesiones || []);
      const allE = allS.flatMap(s => s.ejerciciosCompletados || []);
      const allR = allS.filter(s => s.modulo);
      const allI = allE.filter(e => e.imagenBase64);
      const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v };
      set('sv-u', srvD.usuarios.length); set('sv-s', allS.length); set('sv-e', allE.length);
      set('sv-r', allR.length); set('sv-i', allI.length); set('sv-j', srvD.n);
      set('srv-sc', '(' + srvD.usuarios.length + ')'); set('srv-rc', '(' + allR.length + ')'); set('srv-ic', '(' + allI.length + ')');

      const tb = document.getElementById('srv-tbody');
      if (tb) {
        if (!srvD.usuarios.length) tb.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#8b949e;padding:24px">Carga un JSON para ver datos</td></tr>';
        else { tb.innerHTML = ''; srvD.usuarios.forEach(u => { const ses = u.sesiones || [], ej = ses.flatMap(s => s.ejerciciosCompletados || []), ref = ses.filter(s => s.modulo), imgs = ej.filter(e => e.imagenBase64), ul = ses.slice(-1)[0]?.fecha?.split('T')[0] || '—'; const tr = document.createElement('tr'); tr.innerHTML = `<td style="font-weight:700">${u.nombre}</td><td>${ses.length}</td><td>${ej.length}</td><td>${ref.length}</td><td>${imgs.length}</td><td>${u.puntos || 0}</td><td style="color:#8b949e">${ul}</td>`; tb.appendChild(tr) }) }
      }

      const eg = document.getElementById('srv-em');
      if (eg) { const cut = new Date(); cut.setDate(cut.getDate() - 30); const cnt = {}; EMOTIONS.forEach(e => { cnt[e.id] = 0 }); allS.forEach(s => { if (new Date(s.fecha) >= cut && s.emocionInicio) cnt[s.emocionInicio] = (cnt[s.emocionInicio] || 0) + 1 }); eg.innerHTML = ''; EMOTIONS.forEach(em => { const d = document.createElement('div'); d.className = 'srv-em-pill'; d.innerHTML = `<span class="epi">${em.icon}</span><span class="epn">${em.label}</span><span class="epc">${cnt[em.id] || 0}</span>`; eg.appendChild(d) }) }

      const rl = document.getElementById('srv-refs');
      if (rl) {
        if (!allR.length) rl.innerHTML = '<p style="color:#8b949e;font-size:13px">Sin reflexiones.</p>';
        else { rl.innerHTML = ''; const ents = []; srvD.usuarios.forEach(u => { (u.sesiones || []).filter(s => s.modulo).forEach(s => ents.push({ n: u.nombre, m: s.modulo, f: s.fecha })) }); ents.sort((a, b) => b.f.localeCompare(a.f)).slice(0, 20).forEach(({ n, m, f }) => { const d = document.createElement('div'); d.style.cssText = 'padding:14px;background:rgba(255,255,255,.03);border:1px solid #30363d;border-radius:8px;margin-bottom:10px'; d.innerHTML = `<div style="display:flex;justify-content:space-between;margin-bottom:4px"><strong style="color:#e6edf3">${n}</strong><span style="font-size:11px;color:#8b949e">${f.split('T')[0]}</span></div><div style="font-size:13px;font-weight:700;color:#58a6ff;margin-bottom:4px">${m.titulo}</div><div style="font-size:13px;color:#8b949e;font-style:italic">"${m.texto.slice(0, 150)}${m.texto.length > 150 ? '…' : ''}"</div>`; rl.appendChild(d) }) }
      }

      const gl = document.getElementById('srv-gal');
      if (gl) {
        const imgs = []; srvD.usuarios.forEach(u => { (u.sesiones || []).forEach(s => { (s.ejerciciosCompletados || []).filter(ex => ex.imagenBase64).forEach(ex => { imgs.push({ n: u.nombre, ex, f: s.fecha }) }) }) }); if (!imgs.length) gl.innerHTML = '<p style="color:#8b949e;font-size:13px">Sin imágenes.</p>';
        else { gl.innerHTML = ''; imgs.reverse().slice(0, 30).forEach(({ n, ex, f }) => { const xo = EXERCISES.find(e => e.id === ex.tipo); const d = document.createElement('div'); d.className = 'srv-gi'; d.innerHTML = `<img src="${ex.imagenBase64}" alt="${n}" loading="lazy"><div class="gi"><div class="gin">${n}</div><div>${xo?.icon || '📝'} ${xo?.title || ex.tipo}</div></div>`; d.querySelector('img').onclick = () => openModal(n, ex.reflexionTexto || 'Sin reflexión', ex.imagenBase64); gl.appendChild(d) }) }
      }
    }

    function checkSrvPin() {
      const pin = document.getElementById('srv-pin').value.trim();
      const cfg = getConfig();
      const pinDoc = cfg.pinDocente || DEFAULT_PIN_DOCENTE;
      const pinAdm = cfg.pinAdministrador || DEFAULT_PIN_ADMIN;
      const ok = pin === pinDoc || pin === pinAdm;
      const isAdm = pin === pinAdm;
      if (ok) {
        document.getElementById('srv-pin-wrap').style.display = 'none';
        document.getElementById('srv-panel').style.display = 'block';
        const tag = document.getElementById('srv-role-tag');
        if (tag) tag.textContent = '— ' + (isAdm ? 'Administrador' : 'Docente');
        loadSrv(); srvRender();
      } else {
        const e = document.getElementById('srv-pin-err');
        if (e) { e.style.display = 'block'; setTimeout(() => e.style.display = 'none', 2800) }
        document.getElementById('srv-pin').value = '';
      }
    }
    document.getElementById('srv-pin')?.addEventListener('keydown', e => { if (e.key === 'Enter') checkSrvPin() });

    /* Wire local panel file input (Docente/Admin inside student app) */
    (function () {
      const lfi = document.getElementById('local-file-in');
      const ldz = document.getElementById('local-dz');
      async function localLoad(files) {
        const st = document.getElementById('local-load-st');
        if (st) st.innerHTML = '<div style="background:rgba(88,166,255,.12);border:1px solid rgba(88,166,255,.3);border-radius:8px;padding:10px 14px;font-size:13px;color:#58a6ff;margin-top:8px">🔄 Procesando ' + files.length + ' archivo(s)…</div>';
        let nu = 0, na = 0, ns = 0, errs = [];
        for (const file of [...files].filter(f => f.name.endsWith('.json') || f.type === 'application/json')) {
          await new Promise(res => {
            const r = new FileReader();
            r.onload = e => {
              try {
                const p = JSON.parse(e.target.result);
                if (!p.usuarios || !Array.isArray(p.usuarios)) throw new Error('Falta "usuarios"');
                p.usuarios.forEach(inc => {
                  const d = getUsers();
                  const idx = d.usuarios.findIndex(u => u.id === inc.id || u.nombre.toLowerCase().trim() === inc.nombre.toLowerCase().trim());
                  if (idx === -1) { d.usuarios.push(inc); setUsers(d); nu++; }
                  else {
                    const ex = d.usuarios[idx];
                    const sids = new Set((ex.sesiones || []).map(s => s.id)); let added = 0;
                    (inc.sesiones || []).forEach(s => { if (!sids.has(s.id)) { (ex.sesiones = ex.sesiones || []).push(s); added++ } });
                    ex.puntos = Math.max(ex.puntos || 0, inc.puntos || 0);
                    const ll = new Set(ex.logros || []); (inc.logros || []).forEach(l => ll.add(l)); ex.logros = [...ll];
                    d.usuarios[idx] = ex; setUsers(d); if (added > 0) { na++; ns += added; }
                  }
                });
              } catch (err) { errs.push(file.name + ': ' + err.message) }
              res();
            };
            r.onerror = () => { errs.push(file.name + ': Error de lectura'); res() };
            r.readAsText(file, 'utf-8');
          });
        }
        let html = '';
        if (nu || na) html += `<div style="background:rgba(35,134,54,.15);border:1px solid rgba(35,134,54,.3);border-radius:8px;padding:10px 14px;font-size:13px;color:#56d364;margin-top:8px">✅ ${[...files].length} archivo(s) procesado(s) · ${nu} usuario(s) nuevo(s) · ${na} actualizado(s) · ${ns} sesión(es) agregada(s)</div>`;
        errs.forEach(e => { html += `<div style="background:rgba(248,81,73,.15);border:1px solid rgba(248,81,73,.3);border-radius:8px;padding:10px 14px;font-size:13px;color:#ff7b72;margin-top:6px">❌ ${e}</div>` });
        if (st) st.innerHTML = html;
        // Refresh teacher panel
        if (typeof buildTeacher === 'function') setTimeout(buildTeacher, 300);
        toast(nu + na > 0 ? '✅ Datos importados correctamente' : '⚠️ Sin datos nuevos importados');
      }
      if (lfi) lfi.addEventListener('change', () => { if (lfi.files.length) localLoad(lfi.files) });
      if (ldz) {
        ldz.addEventListener('dragover', e => { e.preventDefault(); ldz.style.borderColor = '#F2A900'; ldz.style.background = 'rgba(242,169,0,.06)' });
        ldz.addEventListener('dragleave', () => { ldz.style.borderColor = 'rgba(255,255,255,.2)'; ldz.style.background = 'rgba(255,255,255,.03)' });
        ldz.addEventListener('drop', e => { e.preventDefault(); ldz.style.borderColor = 'rgba(255,255,255,.2)'; ldz.style.background = 'rgba(255,255,255,.03)'; if (e.dataTransfer.files.length) localLoad(e.dataTransfer.files) });
      }
    })();

    (function () {
      const fi = document.getElementById('srv-file-in');
      const dz = document.getElementById('srv-dz');
      if (fi) fi.addEventListener('change', () => { if (fi.files.length) srvLoad(fi.files) });
      if (dz) {
        dz.addEventListener('dragover', e => { e.preventDefault(); dz.style.borderColor = '#F2A900'; dz.style.background = 'rgba(242,169,0,.06)' });
        dz.addEventListener('dragleave', () => { dz.style.borderColor = 'rgba(255,255,255,.2)'; dz.style.background = 'rgba(255,255,255,.03)' });
        dz.addEventListener('drop', e => { e.preventDefault(); dz.style.borderColor = 'rgba(255,255,255,.2)'; dz.style.background = 'rgba(255,255,255,.03)'; if (e.dataTransfer.files.length) srvLoad(e.dataTransfer.files) });
      }
    })();

    document.getElementById('s-exp-html')?.addEventListener('click', () => {
      let h = `<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8"><title>Reporte ACTiva Arte</title><style>body{font-family:Arial,sans-serif;max-width:960px;margin:40px auto;padding:24px;color:#1A1A2E}h1{color:#003B71;border-bottom:3px solid #F2A900;padding-bottom:8px}h2{color:#005DA4;margin-top:28px}table{width:100%;border-collapse:collapse}th{background:#003B71;color:#fff;padding:9px 12px;text-align:left}td{border:1px solid #ddd;padding:9px 12px}img{max-width:200px;border-radius:8px}.e{border:1px solid #ddd;border-radius:8px;padding:16px;margin:10px 0}</style></head><body><h1>📊 Reporte ACTiva Arte — UNAD</h1><p>Fecha: ${new Date().toLocaleString('es-CO')} · Estudiantes: ${srvD.usuarios.length}</p><h2>👥 Estudiantes</h2><table><thead><tr><th>Nombre</th><th>Sesiones</th><th>Ejercicios</th><th>Reflexiones</th><th>Puntos</th></tr></thead><tbody>`;
      srvD.usuarios.forEach(u => { const ses = u.sesiones || []; h += `<tr><td><strong>${u.nombre}</strong></td><td>${ses.length}</td><td>${ses.flatMap(s => s.ejerciciosCompletados || []).length}</td><td>${ses.filter(s => s.modulo).length}</td><td>${u.puntos || 0}</td></tr>` });
      h += `</tbody></table><h2>✍️ Reflexiones</h2>`;
      srvD.usuarios.forEach(u => { (u.sesiones || []).filter(s => s.modulo).forEach(s => { h += `<div class="e"><strong>${u.nombre}</strong> — ${s.fecha.split('T')[0]}<p style="font-weight:700">${s.modulo.titulo}</p><p style="font-style:italic">"${s.modulo.texto}"</p>${s.modulo.imagenBase64 ? `<img src="${s.modulo.imagenBase64}">` : ''}</div>` }) });
      h += `</body></html>`;
      const b = new Blob([h], { type: 'text/html' }); const a = document.createElement('a'); a.href = URL.createObjectURL(b); a.download = 'Reporte_ACTivaArte_' + new Date().toISOString().slice(0, 10) + '.html'; a.click(); URL.revokeObjectURL(a.href)
    });
    document.getElementById('s-exp-csv')?.addEventListener('click', () => {
      let c = 'Nombre,Sesiones,Ejercicios,Reflexiones,Imagenes,Puntos\n';
      srvD.usuarios.forEach(u => { const ses = u.sesiones || [], ej = ses.flatMap(s => s.ejerciciosCompletados || []), ref = ses.filter(s => s.modulo), imgs = ej.filter(e => e.imagenBase64); c += `"${u.nombre.replace(/"/g, '""')}",${ses.length},${ej.length},${ref.length},${imgs.length},${u.puntos || 0}\n` });
      const b = new Blob([c], { type: 'text/csv;charset=utf-8;' }); const a = document.createElement('a'); a.href = URL.createObjectURL(b); a.download = 'ACTivaArte_' + new Date().toISOString().slice(0, 10) + '.csv'; a.click(); URL.revokeObjectURL(a.href)
    });
    document.getElementById('s-exp-json')?.addEventListener('click', () => {
      const b = new Blob([JSON.stringify({ exportado: new Date().toISOString(), ...srvD }, null, 2)], { type: 'application/json' }); const a = document.createElement('a'); a.href = URL.createObjectURL(b); a.download = 'ACTivaArte_datos_' + new Date().toISOString().slice(0, 10) + '.json'; a.click(); URL.revokeObjectURL(a.href)
    });
    document.getElementById('s-clear')?.addEventListener('click', () => { if (confirm('¿Borrar todos los datos compilados?')) { srvD = { usuarios: [], n: 0 }; localStorage.removeItem(SRV_KEY); srvRender(); const st = document.getElementById('srv-load-st'); if (st) st.innerHTML = '<div class="srv-alert warn">🗑 Datos borrados.</div>' } });

    /* ════════════════ INIT ════════════════ */
    (function boot() {
      const srv = document.getElementById('server-mode');
      const stu = document.getElementById('student-mode');
      if (!srv || !stu) { console.error('Root elements missing'); return }
      if (IS_SRV) { srv.style.display = 'block'; stu.style.display = 'none' }
      else {
        srv.style.display = 'none'; stu.style.display = 'block';
        init();
        setTimeout(updSync, 300);
        if (!_online) setTimeout(() => connBar('offline', '📴 Sin conexión — modo offline'), 900);
        if (_online && gQ().length && gURL()) setTimeout(autoSync, 5000)
      }
    })();


  </script>
