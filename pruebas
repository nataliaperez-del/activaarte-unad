    function calcEmotionScore(selectedIds) {
      if (!selectedIds || !selectedIds.length) return { score: 0, label: '—', tieneNegativa: false, tipoPuro: null };
      const emObjs = selectedIds.map(id => EMOTIONS.find(e => e.id === id)).filter(Boolean);
      const totalScore = emObjs.reduce((a, e) => a + e.score, 0);
      const avg = Math.round(totalScore / emObjs.length);
      const tieneNegativa = emObjs.some(e => e.valencia === 'negativa');
      const tienePositiva = emObjs.some(e => e.valencia === 'positiva');
      const tieneNeutral = emObjs.some(e => e.valencia === 'neutral');
      let tipoPuro = null;
      if (!tieneNegativa && !tieneNeutral) tipoPuro = 'positiva';
      else if (!tieneNegativa && !tienePositiva) tipoPuro = 'neutral';
      return { score: avg, tieneNegativa, tienePositiva, tieneNeutral, tipoPuro };
    }

    function getSmartRecommendation(selectedIds) {
      const emObjs = selectedIds.map(id => EMOTIONS.find(e => e.id === id)).filter(Boolean);

      let matchRule = TRIAGE_RULES.default;

      if (emObjs.some(e => TRIAGE_RULES.defusion_yo.emociones.includes(e.id))) {
