      <button class="btn-stop-ex" onclick="showScreen('screen-dashboard')">
        ⚠️ Necesito pausar — volver al tablero
      </button>
    </div>`;

      det.innerHTML = html;

      // ── Post-emoción mini grid ───────────────────────────────────────────────
      const postGrid = document.getElementById('post-emotion-grid');
      if (postGrid) {
        EMOTIONS.forEach(em => {
          const btn = document.createElement('button');
          const vc = em.valencia === 'positiva' ? 'pos' : em.valencia === 'neutral' ? 'neu' : 'neg';
          btn.className = 'emotion-pill ' + vc;
          btn.style.cssText = 'padding:10px 6px 8px;border-radius:12px';
          btn.innerHTML = `<span class="em-icon" style="font-size:1.4rem">${em.icon}</span><span class="em-label" style="font-size:10px">${em.label}</span>`;
          btn.addEventListener('click', () => {
            postGrid.querySelectorAll('.emotion-pill').forEach(x => { x.classList.remove('selected'); });
            btn.classList.add('selected');
            document.getElementById('input-feeling').value = em.id;
          });
          postGrid.appendChild(btn);
        });
      }

      // ── Contadores de texto ──────────────────────────────────────────────────
      if (ex.pasos) {
        ex.pasos.forEach((paso, pi) => {
          if (paso.tipo === 'reflexion') {
            const el = document.getElementById('prompt-' + pi);
            const cnt = document.getElementById('pcnt-' + pi);
            if (el && cnt) el.addEventListener('input', () => {
              const l = el.value.length, m = paso.min || 10;
              cnt.textContent = l + ' / 1500 (mín. ' + m + ')';
              cnt.className = 'char-counter ' + (l >= m ? 'ok' : '');
              updateExProgress();
            });
          }
          else if (paso.tipo === 'grounding' && ex.groundingLabels) {
            ex.groundingLabels.forEach((_, gi) => {
              const el = document.getElementById('grounding-' + gi);
              const cnt = document.getElementById('gcnt-' + gi);
              if (el && cnt) el.addEventListener('input', () => { cnt.textContent = el.value.length + ' caracteres'; updateExProgress(); });
            });
          }
        });
        // Reflexión post-grounding
        if (ex.pasos.find(p => p.tipo === 'grounding')) {
          const refIdx = ex.pasos.findIndex(p => p.tipo !== 'grounding' && p.tipo === 'reflexion');
          if (refIdx >= 0) {
            const el2 = document.getElementById('prompt-' + refIdx);
            if (el2) el2.addEventListener('input', updateExProgress);
          }
        }
      } else {
        if (ex.grounding) {
          for (let i = 0; i < 6; i++) {
            const el = document.getElementById('grounding-' + i);
            const cnt = document.getElementById('gcnt-' + i);
            if (el && cnt) el.addEventListener('input', () => { cnt.textContent = el.value.length + ' caracteres'; updateExProgress(); });
          }
        }
        if (ex.prompts && !ex.grounding) {
          ex.prompts.forEach((_, i) => {
            const el = document.getElementById('prompt-' + i);
            const cnt = document.getElementById('pcnt-' + i);
            if (el && cnt) el.addEventListener('input', () => { cnt.textContent = el.value.length + ' / 1000'; cnt.className = 'char-counter ' + (el.value.length >= 10 ? 'ok' : ''); updateExProgress(); });
          });
        }
      }

      // ── Preview imagen ───────────────────────────────────────────────────────
      const imgInput = document.getElementById('input-image');
      const preview = document.getElementById('upload-preview');
      const badge = document.getElementById('upload-download-badge');
      if (imgInput) imgInput.addEventListener('change', () => {
        const file = imgInput.files[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) { openModal('Imagen muy grande', 'La foto no puede superar 5MB.'); imgInput.value = ''; return; }
        const reader = new FileReader();
        reader.onload = e => { if (preview) { preview.src = e.target.result; preview.style.display = 'block'; } if (badge) badge.style.display = 'inline-flex'; };
        reader.readAsDataURL(file);
      });

      // ── Rating badge visual ──────────────────────────────────────────────────
      const ratingInput = document.getElementById('input-rating');
      const ratingBadge = document.getElementById('rating-badge');
      const ratingDesc = document.getElementById('rating-desc');
      const ratingDescs = ['', 'Muy difícil', 'Difícil', 'Algo difícil', 'Regular', 'Neutro', 'Útil', 'Bastante útil', 'Muy útil', '¡Excelente!', '¡Transformador!'];
      if (ratingInput && ratingBadge) ratingInput.addEventListener('input', e => {
        const v = parseInt(e.target.value);
        ratingBadge.textContent = v;
        ratingBadge.className = 'rating-badge' + (v >= 8 ? ' great' : v >= 6 ? ' good' : '');
        if (ratingDesc) ratingDesc.textContent = ratingDescs[v] || '';
      });

      // ── Valores chips ────────────────────────────────────────────────────────
      const valGrid = document.getElementById('values-grid');
      if (valGrid) {
        valGrid.addEventListener('click', e => {
          const chip = e.target.closest('.valor-chip');
          if (!chip) return;
          const already = chip.classList.contains('selected');
          if (!already && state.selectedValues.length >= 5) { toast('⚠️ Máximo 5 valores'); return; }
          chip.classList.toggle('selected');
          chip.setAttribute('aria-checked', String(!already));
          if (already) state.selectedValues = state.selectedValues.filter(v => v !== chip.dataset.val);
          else state.selectedValues.push(chip.dataset.val);
          const vc = document.getElementById('valores-count');
          if (vc) vc.textContent = state.selectedValues.length + ' / 5 seleccionados';
        });
        valGrid.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); e.target.click(); } });
      }

      // ── Animación de respiración con timer ──────────────────────────────────
      if (ex.breathe || ex.pasos?.some(p => p.tipo === 'respiracion')) {
        startBreatheAnimation();
      }

      document.getElementById('save-exercise')?.addEventListener('click', () => saveExercise());
      showScreen('screen-exercise');
      updateExProgress();
    }

    function updateExProgress() {
      const ex = EXERCISES.find(x => x.id === state.activeExercise);
      if (!ex) return;
      const fill = document.getElementById('ex-prog-fill');
      if (!fill) return;
      let completed = 0, total = 0;
      if (ex.pasos) {
        ex.pasos.forEach((paso, pi) => {
          if (paso.tipo === 'reflexion') { total++; const el = document.getElementById('prompt-' + pi); if (el && el.value.trim().length >= (paso.min || 10)) completed++; }
          else if (paso.tipo === 'valores') { total++; if (state.selectedValues.length >= 5) completed++; }
          else if (paso.tipo === 'grounding' && ex.groundingLabels) {
            ex.groundingLabels.forEach((_, gi) => { total++; const el = document.getElementById('grounding-' + gi); if (el && el.value.trim().length >= 5) completed++; });
          }
        });
      }
      fill.style.width = total > 0 ? Math.round((completed / total) * 100) + '%' : '0%';
    }

    let breatheTimer = null;
    function startBreatheAnimation() {
      if (breatheTimer) clearInterval(breatheTimer);
      const phases = [
        { label: 'Inhala', dur: 4, color: 'rgba(242,169,0,.5)' },
        { label: 'Sostén', dur: 2, color: 'rgba(255,255,255,.3)' },
        { label: 'Exhala', dur: 6, color: 'rgba(0,93,164,.5)' },
        { label: 'Sostén', dur: 2, color: 'rgba(255,255,255,.2)' }
      ];
      let pi = 0, count = 0;
      function tick() {
        const ph = phases[pi];
        const pEl = document.getElementById('breathe-phase');
        const cEl = document.getElementById('breathe-count');
        const ring = document.getElementById('breathe-ring');
        if (!pEl || !cEl) { clearInterval(breatheTimer); return; }
        if (count === 0) {
          pEl.textContent = ph.label;
          if (ring) ring.style.background = 'radial-gradient(circle,' + ph.color + ' 0%,rgba(0,59,113,.3) 70%,transparent 100%)';
        }
        cEl.textContent = ph.dur - count;
        count++;
        if (count >= ph.dur) { count = 0; pi = (pi + 1) % phases.length; }
      }
      tick();
      breatheTimer = setInterval(tick, 1000);
    }

    /* ============================================================
       GUARDAR EJERCICIO
    ============================================================ */
    function saveExercise() {
      const ex = EXERCISES.find(x => x.id === state.activeExercise);
      if (!ex) { openModal('Error', 'No hay ejercicio activo.'); return; }

      // ── Recolectar reflexiones según estructura ──────────────────────────────
      let reflexionTexto = '';
      let reflexiones = [];

      if (ex.pasos) {
        ex.pasos.forEach((paso, pi) => {
          if (paso.tipo === 'reflexion') {
            const val = document.getElementById('prompt-' + pi)?.value.trim() || '';
            if (val) reflexiones.push(paso.titulo + ': ' + val);
            if (val.length < (paso.min || 10)) {
              openModal('Reflexión incompleta', 'Por favor completa: "' + paso.titulo + '". Escribe al menos ' + (paso.min || 10) + ' caracteres.');
              throw new Error('validation');
            }
          }
          else if (paso.tipo === 'accion_comprometida') {
            const val = document.getElementById('prompt-' + pi)?.value.trim() || '';
            if (val) reflexiones.push(paso.titulo + ': ' + val);
            if (val.length < (paso.min || 10)) {
              openModal('Acción incompleta', 'Formula una acción observable y específica en: "' + paso.titulo + '"');
              throw new Error('validation');
            }
          }
          else if (paso.tipo === 'valores') {
            if (state.selectedValues.length < 5) {
              openModal('Selecciona tus valores', 'Este ejercicio requiere seleccionar exactamente 5 valores que te representen.');
              throw new Error('validation');
            }
            const vals = state.selectedValues.map(i => ex.values?.[i] || '').filter(Boolean).join(', ');
            if (vals) reflexiones.push('Mis valores: ' + vals);
          }
          else if (paso.tipo === 'grounding' && ex.groundingLabels) {
            let groundParts = [];
            ex.groundingLabels.forEach((g, gi) => {
              const val = document.getElementById('grounding-' + gi)?.value.trim() || '';
              if (val.length < 5) {
                openModal('Ejercicio incompleto', 'Completa el sentido "' + g.sentido + '". Escribe al menos 5 caracteres.');
                throw new Error('validation');
              }
              groundParts.push(g.n + ' ' + g.sentido + ': ' + val);
            });
            reflexiones.push(...groundParts);
          }
        });
      } else {
        // Fallback legacy
        if (ex.grounding) {
          const gVals = [...document.querySelectorAll('[id^="grounding-"]')].map(t => t.value.trim());
          if (gVals.some(v => v.length < 3)) {
            openModal('Completa todas las respuestas', 'Cada sentido es obligatorio.');
            return;
          }
          reflexionTexto = gVals.filter(Boolean).join(' | ');
        }
        if (ex.prompts && !ex.grounding) {
          const pVals = ex.prompts.map((_, i) => document.getElementById('prompt-' + i)?.value.trim() || '');
          if (pVals.some(v => v.length < 10)) {
            openModal('Reflexión incompleta', 'Cada pregunta requiere al menos 10 caracteres.');
            return;
          }
          reflexionTexto = pVals.filter(Boolean).join(' | ');
        }
        if (ex.values && state.selectedValues.length < 5) {
          openModal('Selecciona valores', 'Selecciona al menos 5 valores.');
          return;
        }
        const vals = state.selectedValues.map(i => ex.values?.[i] || '').filter(Boolean).join(', ');
        if (vals) reflexionTexto += (reflexionTexto ? ' | ' : '') + 'Valores: ' + vals;
      }

      if (reflexiones.length) reflexionTexto = reflexiones.join('\n');

      // ── Emoción post-ejercicio ────────────────────────────────────────────────
      const finalEmotion = document.getElementById('input-feeling')?.value;
      if (!finalEmotion) {
        openModal('¿Cómo quedaste?', 'Toca una emoción del panel inferior para indicar cómo te sientes después del ejercicio.');
        return;
      }

      const rating = parseInt(document.getElementById('input-rating')?.value, 10) || 5;
      const postMetrics = {
        fusion: parseInt(document.getElementById('post-fusion')?.value || 5),
        evitacion: parseInt(document.getElementById('post-evitacion')?.value || 5),
        valores: parseInt(document.getElementById('post-valores')?.value || 5)
      };

      const file = document.getElementById('input-image')?.files[0];

      // Deshabilitar botón para evitar doble clic
      const btn = document.getElementById('save-exercise');
      if (btn) { btn.disabled = true; btn.innerHTML = '<span>⏳</span> Guardando...'; }

      compressImage(file, imgBase64 => {
        try {
          const user = getUserById(state.user.id);
          const session = user.sesiones.find(s => s.id === state.sessionId);
          if (!session) { openModal('Error de sesión', 'Vuelve al tablero e intenta de nuevo.'); if (btn) { btn.disabled = false; btn.innerHTML = '<span>✓</span> Guardar y completar ejercicio'; } return; }

          const entry = {
            tipo: ex.id, titulo: ex.title, fecha: new Date().toISOString(),
            reflexionTexto, imagenBase64: imgBase64 || null, puntuacion: rating, duracion: ex.tiempo,
            emocionFinal: finalEmotion, emocionesInicio: state.emotions || [],
            metricsPost: postMetrics
          };

          session.ejerciciosCompletados = session.ejerciciosCompletados || [];
          const idx = session.ejerciciosCompletados.findIndex(e => e.tipo === ex.id);
          if (idx >= 0) session.ejerciciosCompletados[idx] = entry; else session.ejerciciosCompletados.push(entry);

          // Puntos: base + bonus por contenido + multiplicador racha
          let pts = 10;
          if (imgBase64) pts += 5;
          if (reflexionTexto.length > 80) pts += 5;
          if (rating >= 8) pts += 3;
          const streak = calcStreak(user.id);
          if (streak >= 7) pts = Math.round(pts * 2);
          else if (streak >= 3) pts = Math.round(pts * 1.5);
          user.puntos = (user.puntos || 0) + pts;

          saveUser(user);
          state.points = user.puntos; saveState(); updateHeaderPoints();
          checkLogros(user);

          if (btn) { btn.innerHTML = '✅ ¡Guardado! +' + pts + ' puntos'; btn.classList.add('celebrating'); }
          toast('🎉 ¡Completado! +' + pts + ' puntos');

          // Mostrar breve pantalla de celebración
          setTimeout(() => {
            showCompletionScreen(ex, pts, finalEmotion);
          }, 700);
        } catch (e2) {
          if (btn) { btn.disabled = false; btn.innerHTML = '<span>✓</span> Guardar y completar ejercicio'; }
        }
      });
    }

    /* Pantalla de celebración post-ejercicio */
    function showCompletionScreen(ex, pts, finalEmotionId) {
      const finalEm = EMOTIONS.find(e => e.id === finalEmotionId);
      const det = document.getElementById('exercise-detail');
      if (!det) { buildDashboard(); showScreen('screen-dashboard'); return; }

      const scoreInfo = state.emotions?.length ? calcEmotionScore(state.emotions) : null;
      const finalScore = finalEm ? finalEm.score : 5;
      const inicioScore = scoreInfo ? scoreInfo.score : 5;
      const mejoro = finalScore > inicioScore;
      const igual = Math.abs(finalScore - inicioScore) < 2;

      const mensajes = [
        '¡Cada ejercicio que completas es una semilla de bienestar!',
        'Lo que sientes importa. Gracias por dedicarte este tiempo.',
        'La consistencia es lo que transforma — y tú acabas de dar un paso.',
        'Tu yo futuro te agradecerá haber estado aquí hoy.',
        'Pequeños momentos de conciencia crean grandes cambios.'
      ];
      const msg = mensajes[Math.floor(Math.random() * mensajes.length)];

      det.innerHTML = `
    <div style="text-align:center;padding:40px 24px 20px;animation:fadeUp .4s ease">
      <div style="font-size:4rem;margin-bottom:10px">${mejoro ? '🌟' : igual ? '✨' : '💙'}</div>
      <h2 style="font-family:'Lora',serif;font-size:1.4rem;color:var(--azul);margin-bottom:8px">
