    ============================================================ */
    let state = { mode: null, rol: null, user: null, emotion: null, emotions: [], sessionId: null, activeExercise: null, points: 0, selectedValues: [] };

    function loadState() { try { const s = sessionStorage.getItem(STATE_KEY); if (s) Object.assign(state, JSON.parse(s)); } catch { } }
    function saveState() { try { sessionStorage.setItem(STATE_KEY, JSON.stringify(state)); } catch { } }

    /* ============================================================
       PERSISTENCIA — localStorage
    ============================================================ */
    function getUsers() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{"usuarios":[]}'); }
      catch { return { usuarios: [] }; }
    }
    function setUsers(data) { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }

    function getConfig() {
      try { return JSON.parse(localStorage.getItem(DOC_KEY) || JSON.stringify({ pinDocente: DEFAULT_PIN_DOCENTE, pinAdministrador: DEFAULT_PIN_ADMIN, nombreDocente: 'Profa. UNAD', grupoNombre: 'Vereda' })); }
      catch { return { pinDocente: DEFAULT_PIN_DOCENTE, pinAdministrador: DEFAULT_PIN_ADMIN, nombreDocente: 'Profa. UNAD', grupoNombre: 'Vereda' }; }
    }
    function setConfig(cfg) { localStorage.setItem(DOC_KEY, JSON.stringify(cfg)); }

    function getUserById(id) { return getUsers().usuarios.find(u => u.id === id); }

    function saveUser(user) {
      const data = getUsers();
      const idx = data.usuarios.findIndex(u => u.id === user.id);
      if (idx >= 0) data.usuarios[idx] = user; else data.usuarios.push(user);
      setUsers(data);
    }

    function createOrGetUser(name, rol = 'estudiante') {
      const data = getUsers();
      let user = data.usuarios.find(u => u.nombre.toLowerCase() === name.toLowerCase().trim());
      if (!user) {
        user = { id: 'u-' + Date.now(), nombre: name.trim(), rol: rol, fechaRegistro: new Date().toISOString(), sesiones: [], puntos: 0, logros: [], consent: false };
        data.usuarios.push(user); setUsers(data);
      } else {
        // Actualizar rol si cambió
        if (user.rol !== rol) { user.rol = rol; saveUser(user); }
      }
      state.user = user; saveState();
    }

    function getOrCreateSession(metricsPre = null) {
      const user = getUserById(state.user.id);
      const today = new Date().toISOString().split('T')[0];
      let session = user.sesiones?.find(s => s.fecha.startsWith(today));
      if (!session) {
        session = { id: 's-' + Date.now(), fecha: new Date().toISOString(), emocionInicio: state.emotion, emocionesInicio: state.emotions || [], emocionFin: '', ejerciciosCompletados: [], modulo: null, metricsPre: metricsPre };
        user.sesiones = user.sesiones || [];
        user.sesiones.push(session);
        saveUser(user);
      } else if (metricsPre && !session.metricsPre) {
        session.metricsPre = metricsPre;
        saveUser(user);
      }
      state.sessionId = session.id;
      saveState();
      return session;
    }

    /* ============================================================
       RACHA Y ESTADÍSTICAS
    ============================================================ */
    function calcStreak(uid) {
      const user = getUserById(uid);
      if (!user || !user.sesiones || !user.sesiones.length) return 0;
      const dias = [...new Set(user.sesiones.map(s => s.fecha.split('T')[0]))].sort((a, b) => b.localeCompare(a));
      let streak = 0, ref = new Date(); ref.setHours(23, 59, 59);
      for (const d of dias) {
        const date = new Date(d + 'T23:59:59');
        const diff = (ref - date) / (1000 * 60 * 60 * 24);
        if (diff < 1.5) { streak++; ref.setDate(ref.getDate() - 1); }
        else break;
      }
      return streak;
    }

    function getWeekDays() {
      const days = [];
      for (let i = 6; i >= 0; i--) {
        const d = new Date(); d.setDate(d.getDate() - i);
        days.push(d.toISOString().split('T')[0]);
      }
      return days;
    }

    /* Contar emociones en los últimos N días */
    function countEmotionsLastDays(sesiones, days = 30) {
      const cutoff = new Date(); cutoff.setDate(cutoff.getDate() - days);
      const count = {};
      EMOTIONS.forEach(e => { count[e.id] = 0; });
      sesiones.forEach(s => {
        if (new Date(s.fecha) < cutoff) return;
        const ids = Array.isArray(s.emocionesInicio) && s.emocionesInicio.length
          ? s.emocionesInicio
          : (s.emocionInicio ? [s.emocionInicio] : []);
        ids.forEach(id => { if (count.hasOwnProperty(id)) count[id]++; });
      });
      return count;
    }

    /* ============================================================
       UI HELPERS
    ============================================================ */
    function showScreen(id) {
      const overlay = document.getElementById('modal-overlay');
      if (overlay) {
        overlay.classList.remove('show');
        overlay.style.display = 'none';
        overlay.style.pointerEvents = 'none';
      }
      // Limpiar timer de respiración al salir del ejercicio
      if (id !== 'screen-exercise' && typeof breatheTimer !== 'undefined' && breatheTimer) {
        clearInterval(breatheTimer); breatheTimer = null;
      }
      document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
      const sc = document.getElementById(id);
      if (sc) { sc.classList.add('active'); window.scrollTo({ top: 0, behavior: 'smooth' }); }
    }

    function toast(text, duration = 3000) {
      const el = document.createElement('div');
      el.className = 'toast'; el.textContent = text;
      document.body.appendChild(el);
      setTimeout(() => { if (el.parentNode) el.remove(); }, duration);
    }

    function openModal(title, text, imgSrc = null) {
      document.getElementById('modal-title').textContent = title;
      document.getElementById('modal-text').textContent = text;
      const img = document.getElementById('modal-img');
      if (imgSrc) { img.src = imgSrc; img.style.display = 'block'; }
      else { img.style.display = 'none'; }
      const overlay = document.getElementById('modal-overlay');
      overlay.classList.add('show');
      overlay.style.display = 'flex';
      overlay.style.pointerEvents = 'auto';
    }
    function closeModal() {
      const overlay = document.getElementById('modal-overlay');
      overlay.classList.remove('show');
      overlay.style.display = 'none';
      overlay.style.pointerEvents = 'none';
      document.getElementById('modal-img').style.display = 'none';
    }

    function updateHeaderPoints() {
      const pts = state.user?.puntos || state.points || 0;
      document.getElementById('header-points').textContent = pts + ' pts';
    }

    /* Contador de caracteres */
    function setupCharCounter(inputId, counterId, min = 0) {
      const el = document.getElementById(inputId);
      const cnt = document.getElementById(counterId);
      if (!el || !cnt) return;
      const max = el.maxLength || 9999;
      const update = () => {
        const len = el.value.length;
        if (min > 0) cnt.textContent = len + ' / ' + max + ' (mín. ' + min + ')';
        else cnt.textContent = len + ' / ' + max;
        cnt.className = 'char-counter ' + (len >= max ? 'warn' : len >= min && min > 0 ? 'ok' : '');
      };
      el.addEventListener('input', update);
      update();
    }

    /* ============================================================
       PANTALLA 0: SELECTOR DE ROL
    ============================================================ */
    let selectedRole = null;

    function selectRole(rol) {
      selectedRole = rol;
      document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
      const target = document.querySelector('[data-role="' + rol + '"]');
      if (target) target.classList.add('selected');
      const btn = document.getElementById('btn-continue-role');
      if (btn) btn.disabled = false;
    }

    // Utilizada en btn-continue-role y btn-accept-consent
    function handleRoleSelection() {
      if (!selectedRole) { alert('Selecciona un rol primero'); return; }
      if (selectedRole === 'profesor' || selectedRole === 'administrador') {
        const cfg = getConfig();
        let targetPin = selectedRole === 'profesor' ? cfg.pinDocente : cfg.pinAdministrador;

        if (targetPin === '' || targetPin === undefined || targetPin === null) {
          const newPin = prompt(`No hay PIN configurado para ${selectedRole}.\nPor favor, crea un nuevo PIN para asegurar el panel (mín. 4 caracteres):`);
          if (!newPin || newPin.trim().length < 4) { openModal('Cancelado', 'Se requiere PIN válido para proteger los datos.'); return; }
          if (selectedRole === 'profesor') cfg.pinDocente = newPin.trim();
          else cfg.pinAdministrador = newPin.trim();
          setConfig(cfg);
          targetPin = newPin.trim();
          toast('🔑 PIN ' + selectedRole + ' configurado exitosamente.');
        }

        const pin = prompt('PIN de acceso:');
        if (!pin) return;
        if (pin.trim() === targetPin) {
          state.mode = selectedRole; saveState();
          buildTeacher(); showScreen('screen-teacher');
        } else {
          openModal('PIN incorrecto', 'Verifica el código (o contacta al administrador si lo olvidaste).');
        }
        return;
      }
      showScreen('screen-consent');
    }

    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('btn-continue-role')?.addEventListener('click', (e) => {
        e.stopPropagation(); e.preventDefault();
        handleRoleSelection();
      });

      document.getElementById('btn-accept-consent')?.addEventListener('click', (e) => {
        const name = prompt('¿Cuál es tu nombre? (o un alias si lo prefieres)');
        if (!name || !name.trim()) return;
        createOrGetUser(name, selectedRole);
        const user = getUserById(state.user.id);
        user.consent = true;
        saveUser(user);
        state.mode = selectedRole; saveState();
        buildCheckin(); showScreen('screen-checkin');
      });
    });

    /* ============================================================
       PANTALLA 1: CHECK-IN EMOCIONAL
    ============================================================ */
    function buildCheckin() {
      const name = state.user?.nombre || '';
      document.getElementById('checkin-greeting').textContent = 'Hola, ' + name + ' 👋';

      // Hora y fecha actual
      const now = new Date();
      const hora = now.toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit' });
      const fecha = now.toLocaleDateString('es-CO', { weekday: 'long', day: 'numeric', month: 'long' });
      const horaEl = document.getElementById('checkin-hora');
      const fechaEl = document.getElementById('checkin-fecha');
      if (horaEl) horaEl.textContent = hora;
      if (fechaEl) fechaEl.textContent = fecha.charAt(0).toUpperCase() + fecha.slice(1);

      // Alerta patrón negativo
      const user = getUserById(state.user?.id);
      if (user && user.sesiones) {
        const last3 = user.sesiones.slice(-3).map(s => {
          const ids = Array.isArray(s.emocionesInicio) ? s.emocionesInicio : [s.emocionInicio].filter(Boolean);
          const scores = ids.map(id => EMOTIONS.find(e => e.id === id)?.score || 5);
          return scores.length ? scores.reduce((a, b) => a + b, 0) / scores.length : 5;
        });
        const avg = last3.reduce((a, b) => a + b, 0) / (last3.length || 1);
        if (last3.length >= 3 && avg <= 3) document.getElementById('alert-support').classList.add('show');
      }

      // Reset selección
      state.emotions = []; state.emotion = null; saveState();
      document.getElementById('btn-validate').disabled = true;

      const grid = document.getElementById('emotion-grid');
      grid.innerHTML = '';

      const emCount = user ? countEmotionsLastDays(user.sesiones || [], 30) : {};

      EMOTIONS.forEach(em => {
        const cnt = emCount[em.id] || 0;
        const btn = document.createElement('button');
        const valClass = em.valencia === 'positiva' ? 'pos' : em.valencia === 'neutral' ? 'neu' : 'neg';
        btn.className = 'emotion-pill ' + valClass;
        btn.dataset.emId = em.id;
        btn.setAttribute('aria-label', 'Seleccionar emoción: ' + em.label);
        btn.setAttribute('aria-pressed', 'false');
        btn.innerHTML =
          `<span class="em-icon">${em.icon}</span>` +
          `<span class="em-label">${em.label}</span>` +
          `<span class="em-valencia">${em.valencia}</span>` +
          (cnt > 0 ? `<span class="em-count">${cnt}x este mes</span>` : '');
        btn.addEventListener('click', () => {
          const isSelected = btn.classList.contains('selected');
          if (isSelected) {
            btn.classList.remove('selected');
            btn.setAttribute('aria-pressed', 'false');
            state.emotions = state.emotions.filter(id => id !== em.id);
          } else {
            btn.classList.add('selected');
            btn.setAttribute('aria-pressed', 'true');
            state.emotions.push(em.id);
          }
          state.emotion = state.emotions[0] || null;
          saveState();
          updateCheckinFeedback();
          updateEmDots();
          document.getElementById('btn-validate').disabled = state.emotions.length === 0;
        });
        grid.appendChild(btn);
      });

      updateEmDots();
    }

    function updateEmDots() {
      const dotsEl = document.getElementById('em-dots');
      if (!dotsEl) return;
      const n = state.emotions.length;
      dotsEl.innerHTML = Array.from({ length: 9 }, (_, i) =>
        `<span class="em-select-dot" style="
      display:inline-block;width:7px;height:7px;border-radius:50%;margin:0 2px;
      background:${i < n ? 'var(--azul-c)' : 'var(--borde)'};
      transition:background .2s;
    "></span>`
      ).join('');
    }

    function updateCheckinFeedback() {
      const panel = document.getElementById('emotion-feedback-panel');
      if (!panel) return;
      if (!state.emotions || !state.emotions.length) { panel.style.display = 'none'; return; }

      const smart = getSmartRecommendation(state.emotions);
      const scoreInfo = calcEmotionScore(state.emotions);
      const emObjs = state.emotions.map(id => EMOTIONS.find(e => e.id === id)).filter(Boolean);

      // Clase de color según tipo dominante
      let cls = 'mix';
      if (scoreInfo.tipoPuro === 'positiva') cls = 'pos';
      else if (scoreInfo.tipoPuro === 'neutral') cls = 'neu';
      else if (scoreInfo.tieneNegativa) cls = 'neg';

      // Barra de bienestar (score 2-10 → 0-100%)
      const pct = Math.round(((scoreInfo.score - 2) / 8) * 100);

      const tags = emObjs.map(em => {
        const vc = em.valencia === 'positiva' ? 'pos' : em.valencia === 'neutral' ? 'neu' : 'neg';
        return `<span class="ef-tag ${vc}">${em.icon} ${em.label}</span>`;
      }).join('');

      // Mensajes enriquecidos con micro-orientación ACT
      const mensajesACT = {
        neg: [
          'Lo que sientes tiene sentido. En ACT no luchamos contra las emociones — las observamos con curiosidad.',
          'Tus emociones no te definen. Tú eres el cielo; ellas son las nubes.',
          'Este momento es difícil, y está bien. Respira y recuerda: esto también pasará.'
        ],
        pos: [
          '¡Qué energía tan valiosa! Este es un buen momento para actuar desde tus valores.',
          'Cuando te sientes bien, es el momento ideal para comprometerte con lo que más importa.',
          'Tu bienestar de hoy es el motor para construir lo que quieres mañana.'
        ],
        neu: [
          'La neutralidad también es un estado válido. Úsalo para observar qué quieres activar hoy.',
          'Desde la calma, puedes elegir con más claridad hacia dónde dirigir tu energía.',
          'El estado neutro es una oportunidad — como una hoja en blanco lista para escribir.'
        ],
        mix: [
          'Tienes una mezcla de emociones — eso es completamente humano.',
          'Sentir varias cosas a la vez no es confusión: es la riqueza de la experiencia humana.',
          'Tu complejidad emocional es una fortaleza, no una debilidad.'
        ]
      };
      const msgs = mensajesACT[cls] || mensajesACT.mix;
      const msg = msgs[Math.floor(Math.random() * msgs.length)];

      panel.style.display = 'block';
      panel.innerHTML = `
    <div class="emotion-feedback ${cls}">
      <div class="ef-label">Tu estado ahora mismo</div>
      <div class="ef-tags">${tags}</div>
      <div class="ef-score-bar"><div class="ef-score-fill" style="width:${pct}%"></div></div>
      <div class="ef-mensaje">${smart.texto}</div>
      <div class="ef-sub">${msg}</div>
      <button class="ef-pill-rec" onclick="startExerciseFromCheckin('${smart.ejercicio}')">
        ▶ Ir directo: ${EXERCISES.find(e => e.id === smart.ejercicio)?.title || 'Terapia recomendada'}
      </button>
    </div>`;
    }

    document.getElementById('btn-validate').addEventListener('click', () => {
      if (!state.emotions || !state.emotions.length) { openModal('Elige tu emoción', 'Toca cómo te sientes hoy para continuar.'); return; }
      const metricsPre = {
        fusion: parseInt(document.getElementById('pre-fusion')?.value || 5),
        evitacion: parseInt(document.getElementById('pre-evitacion')?.value || 5)
      };
      getOrCreateSession(metricsPre);
      const user = getUserById(state.user.id);
      evaluateRisk(user);
      buildDashboard();
      showScreen('screen-dashboard');
    });

    // Wrapper global para que el botón de acceso directo en feedback funcione
    // aunque aún no se haya creado la sesión
    function startExerciseFromCheckin(exId) {
      if (!state.emotions || !state.emotions.length) {
        openModal('Elige tu emoción', 'Selecciona al menos una emoción antes de continuar.');
        return;
      }
      const metricsPre = {
        fusion: parseInt(document.getElementById('pre-fusion')?.value || 5),
        evitacion: parseInt(document.getElementById('pre-evitacion')?.value || 5)
      };
      getOrCreateSession(metricsPre);
      const user = getUserById(state.user.id);
      evaluateRisk(user);
      buildDashboard();
      startExercise(exId);
    }

    /* ============================================================
       PANTALLA 2: DASHBOARD
    ============================================================ */
    function buildDashboard() {
      const user = getUserById(state.user?.id);
      if (!user) return;

      const streak = calcStreak(user.id);
      const pts = user.puntos || 0;
      state.points = pts; updateHeaderPoints();

      document.getElementById('streak-num').textContent = streak;
      document.getElementById('week-number').textContent = Math.max(1, Math.ceil((new Date() - new Date(user.fechaRegistro)) / (1000 * 60 * 60 * 24 * 7)));
      document.getElementById('progress-inner').style.width = Math.min(100, (streak / 7) * 100) + '%';
      document.getElementById('dash-points').textContent = pts;

      const emotions = state.emotions || [];
      const recBox = document.getElementById('today-recommend-box');
      const recTxt = document.getElementById('today-recommend');
      if (emotions.length > 0) {
        const smart = getSmartRecommendation(emotions);
        const scoreInfo = calcEmotionScore(emotions);
        const pct = Math.round(((scoreInfo.score - 2) / 8) * 100);
        const tags = emotions.map(id => {
          const em2 = EMOTIONS.find(e => e.id === id);
          return em2 ? `<span style="background:rgba(255,255,255,.2);border-radius:var(--rp);padding:2px 9px;font-size:12px;font-weight:700">${em2.icon} ${em2.label}</span>` : '';
        }).join('');
        recTxt.innerHTML =
          `<div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px">${tags}</div>` +
          `<div style="height:3px;background:rgba(255,255,255,.15);border-radius:var(--rp);margin-bottom:10px;overflow:hidden"><div style="height:100%;width:${pct}%;background:var(--amarillo);border-radius:var(--rp)"></div></div>` +
          `<div style="font-weight:700;font-size:14px">${smart.texto}</div>`;
        if (recBox) recBox.style.display = 'block';
      }

      const today = new Date().toISOString().split('T')[0];
      const todaySession = user.sesiones?.find(s => s.fecha.startsWith(today));
      const doneToday = todaySession?.ejerciciosCompletados?.map(e => e.tipo) || [];

      const container = document.getElementById('exercise-cards');
      container.innerHTML = '';

      // Ejercicio recomendado según emociones del día
      const smart = state.emotions?.length ? getSmartRecommendation(state.emotions) : null;
      const recId = smart?.ejercicio;

      EXERCISES.forEach(ex => {
        const done = doneToday.includes(ex.id);
        const isRec = ex.id === recId && !done;
        const card = document.createElement('article');
        card.className = 'card-ex' + (done ? ' done' : '') + (isRec ? ' recommended' : '');
        card.setAttribute('role', 'button');
        card.setAttribute('tabindex', '0');
        card.setAttribute('aria-label', (done ? 'Completado: ' : isRec ? 'Recomendado: ' : '') + ex.title);

        if (isRec) {
          card.style.cssText = 'border-color:var(--amarillo);border-width:2px;background:linear-gradient(135deg,rgba(242,169,0,.04),var(--blanco))';
        }
        if (done) {
          card.style.cssText = 'border-color:var(--verde);opacity:.75';
        }

        card.innerHTML =
          (isRec ? '<span style="font-size:9px;font-weight:900;text-transform:uppercase;letter-spacing:.8px;color:var(--amarillo);display:block;margin-bottom:4px">⭐ Recomendado para ti</span>' : '') +
          `<span class="ex-icon" style="font-size:${isRec ? '2.2rem' : '1.8rem'}">${ex.icon}</span>` +
          `<span class="ex-title">${ex.title}</span>` +
          `<span class="ex-sub">${ex.process} · ${ex.tiempo}</span>` +
          `<span class="ex-badge ${done ? 'badge-done' : 'badge-pend'}">${done ? '✓ Completado' : 'Pendiente'}</span>`;

        card.addEventListener('click', () => startExercise(ex.id));
        card.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); startExercise(ex.id); } });
        container.appendChild(card);
      });
    }

    /* ============================================================
       PANTALLA 3: EJERCICIO ACTIVO — INMERSIVO
    ============================================================ */
    function startExercise(exId) {
      state.activeExercise = exId; saveState();
      const ex = EXERCISES.find(x => x.id === exId);
      if (!ex) { toast('Ejercicio no encontrado'); return; }
      state.selectedValues = [];

      const det = document.getElementById('exercise-detail');
      if (!det) { console.error('exercise-detail not found'); return; }
      det.innerHTML = '';

      // ── Cabecera inmersiva ──────────────────────────────────────────────────
      let html = `
    <div class="ex-header">
      <button class="ex-header-back" onclick="showScreen('screen-dashboard')">← Volver</button>
      <div class="ex-header-body">
        <span class="ex-header-icon">${ex.icon}</span>
        <div class="ex-header-title">${ex.title}</div>
        <div class="ex-header-meta">
          <span>⏱ ${ex.tiempo}</span>
          <span>🧠 ${ex.process}</span>
        </div>
        <span class="ex-process-badge">${ex.process}</span>
        <div class="ex-progress-wrap"><div class="ex-progress-fill" id="ex-prog-fill"></div></div>
      </div>
    </div>`;

      // ── Contexto / intro enriquecido ─────────────────────────────────────────
      html += `
    <div class="ex-context">
      <div class="ex-context-quote">${ex.frase || '"' + ex.intro + '"'}</div>
      <div class="ex-context-instr">${ex.intro}</div>
    </div>`;

      // ── Pasos del ejercicio ─────────────────────────────────────────────────
      html += `<div class="ex-body">`;

      // Si tiene pasos estructurados (nuevo formato)
      if (ex.pasos) {
        ex.pasos.forEach((paso, pi) => {
          html += `<div class="ex-step" id="ex-step-${pi}">
        <div class="ex-step-label"><span class="ex-step-num">${pi + 1}</span>${paso.titulo}</div>`;

          if (paso.tipo === 'texto') {
            html += `<p style="font-size:13px;color:var(--txt2);line-height:1.65;background:var(--crema);border-radius:var(--rs);padding:12px 14px;border-left:3px solid var(--salvia)">${paso.desc}</p>`;
          }
          else if (paso.tipo === 'reflexion') {
            html += `
          <label style="font-size:13px;color:var(--txt2);display:block;margin-bottom:8px;">${paso.label}</label>
          <textarea id="prompt-${pi}" class="form-input" rows="${paso.rows || 3}" 
            placeholder="${paso.placeholder || 'Escribe aquí...'}" 
            minlength="${paso.min || 10}" maxlength="1500"
            style="resize:vertical"></textarea>
          <div class="char-counter" id="pcnt-${pi}">0 / 1500 (mín. ${paso.min || 10})</div>`;
          }
          else if (paso.tipo === 'respiracion') {
            html += `
