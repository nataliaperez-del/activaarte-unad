    function drawEmotionChart(days, sesiones) {
      const canvas = document.getElementById('emotion-chart');
      if (!canvas || !canvas.getContext) return;
      const ctx = canvas.getContext('2d');
      canvas.width = canvas.offsetWidth || 340; canvas.height = 160;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const scoreMap = {
        // nuevas 9 emociones
        alegre: 10, entusiasmado: 10, calmo: 10,
        indiferente: 5, cansado: 5, sorprendido: 5,
        triste: 2, ansioso: 2, enojado: 2,
        // legacy
        pesado: 1, frustrado: 2, neutral: 3, bien: 4, muybien: 5
      };
      const PAD = 30, W = canvas.width, H = canvas.height;
      const colW = (W - PAD * 2) / (days.length - 1 || 1);

      for (let i = 1; i <= 5; i++) {
        const y = H - PAD - (i - 1) * (H - PAD * 2) / 4;
        ctx.beginPath(); ctx.strokeStyle = '#E2E8F0'; ctx.lineWidth = 1;
        ctx.moveTo(PAD, y); ctx.lineTo(W - PAD, y); ctx.stroke();
      }

      const pts = days.map((d, i) => {
        const s = sesiones.find(sess => sess.fecha.startsWith(d));
        let score = 5;
        if (s) {
          const ids = Array.isArray(s.emocionesInicio) && s.emocionesInicio.length
            ? s.emocionesInicio : (s.emocionInicio ? [s.emocionInicio] : []);
          const scores = ids.map(id => scoreMap[id] || 5);
          score = scores.length ? scores.reduce((a, b) => a + b, 0) / scores.length : 5;
        }
        // normalize score to 1-5 range for chart (original was 1-5, new is 2-10)
        const norm = Math.max(1, Math.min(5, Math.round(score / 2)));
        return { x: PAD + i * colW, y: H - PAD - (norm - 1) * (H - PAD * 2) / 4 };
      });

      ctx.beginPath(); ctx.strokeStyle = '#003B71'; ctx.lineWidth = 2.5; ctx.lineJoin = 'round';
      pts.forEach((p, i) => { i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y); });
      ctx.stroke();

      const grad = ctx.createLinearGradient(0, 0, 0, H);
      grad.addColorStop(0, 'rgba(0,119,200,0.18)'); grad.addColorStop(1, 'rgba(0,119,200,0)');
      ctx.beginPath();
      pts.forEach((p, i) => { i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y); });
      ctx.lineTo(pts[pts.length - 1].x, H - PAD); ctx.lineTo(pts[0].x, H - PAD); ctx.closePath();
      ctx.fillStyle = grad; ctx.fill();

      pts.forEach((p, i) => {
        ctx.beginPath(); ctx.arc(p.x, p.y, 4, 0, 2 * Math.PI);
        ctx.fillStyle = '#005DA4'; ctx.fill();
        ctx.fillStyle = '#666'; ctx.font = '10px Nunito'; ctx.textAlign = 'center';
        ctx.fillText(days[i].slice(8), p.x, H - 6);
      });
    }

