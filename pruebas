    const SYNC_KEY = 'activa_sync_q_v1', GAS_URL_KEY = 'activa_gas_url_v1', SRV_KEY = 'activa_srv_v1', APP_VER = 'ACTiva Arte v6';
    let _syncing = false, _online = navigator.onLine;
    const gQ = () => { try { return JSON.parse(localStorage.getItem(SYNC_KEY) || '[]') } catch { return [] } };
    const sQ = a => localStorage.setItem(SYNC_KEY, JSON.stringify(a));
    const gURL = () => (localStorage.getItem(GAS_URL_KEY) || '').trim();
    const addQ = uid => { const q = gQ(); if (!q.includes(uid)) q.push(uid); sQ(q); updSync() };
    const clrQ = () => { sQ([]); updSync() };

    window.addEventListener('online', () => { _online = true; connBar('online', '🌐 Conexión restaurada'); updSync(); setTimeout(hideBar, 4000); if (gQ().length && gURL()) setTimeout(autoSync, 1500) });
