      html += `</div>`; // cierre ex-body

      // ── Cierre del ejercicio ─────────────────────────────────────────────────
      html += `
    <div class="ex-close-card">
      <h4>Al terminar — ¿cómo te quedas?</h4>

      <div class="form-group" style="margin-bottom:16px">
        <label class="form-label">¿Cómo te sientes DESPUÉS de este ejercicio?</label>
